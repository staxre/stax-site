---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "STAX Real Estate — Founded by the former CEO of a dozen-location gas station operating company. 180+ stations sold. Bonus depreciation, 1031 exchanges, and off-market deal flow from someone who's owned and operated the business.", ogImage = "/images/hero-shell-station.jpg" } = Astro.props;
const canonicalUrl = Astro.url.href;
const siteUrl = 'https://staxre.com';
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- Open Graph / Social Sharing -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absoluteOgImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="STAX Real Estate" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteOgImage} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="STAX Real Estate Blog" href="/rss.xml" />

  <!-- Structured Data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    "name": "STAX Real Estate",
    "description": "NNN net lease gas station brokerage. 180+ stations sold. Specializing in bonus depreciation, 1031 exchanges, and off-market deal flow.",
    "url": "https://staxre.com",
    "logo": "https://staxre.com/images/stax-logo-black.svg",
    "image": "https://staxre.com/images/hero-shell-station.jpg",
    "telephone": "+1-321-770-0222",
    "email": "michael@staxre.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1111 Lincoln Rd Suite 500",
      "addressLocality": "Miami Beach",
      "addressRegion": "FL",
      "postalCode": "33139",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 25.7907,
      "longitude": -80.1400
    },
    "founder": {
      "@type": "Person",
      "name": "Michael Salafia",
      "jobTitle": "Founder & Principal Broker"
    },
    "areaServed": {
      "@type": "Country",
      "name": "United States"
    },
    "sameAs": [
      "https://www.linkedin.com/company/stax-real-estate"
    ]
  }
  </script>

  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-6D6LJ0Y076"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-6D6LJ0Y076');
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-white">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/97 backdrop-blur-md border-b border-black/5 h-[72px] flex items-center justify-between px-6 lg:px-12">
    <a href="/" class="flex items-center">
      <img src="/images/stax-logo-black.svg" alt="STAX Real Estate" class="h-8 object-contain" />
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="block w-6 h-0.5 bg-gray-900 transition-all"></span>
      <span class="block w-6 h-0.5 bg-gray-900 transition-all"></span>
      <span class="block w-6 h-0.5 bg-gray-900 transition-all"></span>
    </button>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-8">
      <a href="/about" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">About</a>
      <a href="/sellers" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Sellers</a>
      <a href="/buyers" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Investors</a>
      <a href="/operators" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Operators</a>
      <a href="/deals" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Deals</a>
      <a href="/off-market" class="text-sm font-medium text-red hover:text-red-dark transition-colors">Off-Market</a>
      <a href="/case-studies" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Case Studies</a>
      <a href="/press" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Press</a>
      <a href="/blog" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">Blog</a>
      <a href="/contact" class="bg-black text-white text-xs font-semibold tracking-wide px-6 py-2.5 rounded-md hover:bg-gray-900 transition-colors uppercase">Schedule a Call</a>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden fixed inset-0 top-[72px] z-40 p-6 flex flex-col gap-4 lg:hidden" style="background-color: #ffffff;">
      <a href="/about" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">About</a>
      <a href="/sellers" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Sellers</a>
      <a href="/buyers" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Investors</a>
      <a href="/operators" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Operators</a>
      <a href="/deals" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Deals</a>
      <a href="/off-market" class="text-lg font-medium text-red py-2 border-b border-gray-100">Off-Market</a>
      <a href="/case-studies" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Case Studies</a>
      <a href="/press" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Press</a>
      <a href="/blog" class="text-lg font-medium text-gray-900 py-2 border-b border-gray-100">Blog</a>
      <a href="/contact" class="bg-red text-white text-center font-semibold py-3 rounded-md mt-4">Schedule a Call</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="bg-black text-white/50 pt-16 pb-10 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div>
        <img src="/images/stax-logo-white.svg" alt="STAX Real Estate" class="h-8 object-contain mb-3" />
        <p class="text-sm leading-relaxed max-w-[280px]">The operator-broker for gas station sales and NNN investments. 180+ stations sold across income-tax-free states.</p>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wider uppercase text-white/30 mb-4">Services</h4>
        <a href="/sellers" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Sellers</a>
        <a href="/buyers" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Investors</a>
        <a href="/operators" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Operators</a>
        <a href="/valuation" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Valuation</a>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wider uppercase text-white/30 mb-4">Company</h4>
        <a href="/about" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">About</a>
        <a href="/case-studies" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Case Studies</a>
        <a href="/press" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Press</a>
        <a href="/deals" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Deals</a>
        <a href="/blog" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Blog</a>
        <a href="/contact" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">Contact</a>
      </div>
      <div>
        <h4 class="text-xs font-semibold tracking-wider uppercase text-white/30 mb-4">Contact</h4>
        <a href="tel:+13217700222" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">(321) 770-0222</a>
        <a href="mailto:michael@staxre.com" class="block text-sm text-white/60 hover:text-white mb-2.5 transition-colors">michael@staxre.com</a>
        <span class="block text-sm text-white/60 mb-2.5">Miami Beach, FL</span>
      </div>
    </div>
    <div class="max-w-[1200px] mx-auto mt-10 pt-6 border-t border-white/8 text-xs flex flex-col sm:flex-row justify-between gap-2">
      <span>&copy; 2026 STAX Real Estate LLC. All rights reserved.</span>
      <span>1111 Lincoln Rd Suite 500, Miami Beach, FL 33139</span>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
