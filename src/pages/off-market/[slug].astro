---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import {
  getPublishedListings,
  getOffMarketListings,
  formatPrice,
} from '../../lib/listings';
import type { Listing } from '../../lib/listings';

export async function getStaticPaths() {
  const data = await getPublishedListings();
  const offMarket = getOffMarketListings(data);

  return offMarket.map((listing) => ({
    params: { slug: listing.slug },
    props: { listing, allListings: offMarket },
  }));
}

interface Props {
  listing: Listing;
  allListings: Listing[];
}

const { listing, allListings } = Astro.props;

// Off-market: don't expose street address in title/meta
const title = listing.meta_title
  || `Off-Market ${listing.property_type || "Gas Station"} — ${listing.city}, ${listing.state} | STAX Real Estate`;
const description = listing.meta_description
  || `Exclusive off-market ${listing.property_type?.toLowerCase() || "gas station"} opportunity in ${listing.city}, ${listing.state}. Sign our NDA for full property details and financials. STAX Real Estate.`;
const ogImage = listing.hero_image_url || '/images/og-off-market.jpg';

const related = allListings
  .filter((l) => l.slug !== listing.slug)
  .slice(0, 3);

// Build teaser metrics (limited for off-market)
const displayMetrics = listing.metrics && Object.keys(listing.metrics).length > 0
  ? Object.entries(listing.metrics).map(([label, value]) => ({ label, value }))
  : [
      listing.asking_price ? { label: "Asking Price", value: formatPrice(listing.asking_price) } : null,
      listing.ebitda ? { label: "EBITDA", value: formatPrice(listing.ebitda) } : null,
      listing.noi ? { label: "NOI", value: formatPrice(listing.noi) } : null,
    ].filter(Boolean) as Array<{ label: string; value: string }>;

const highlights = listing.highlights ?? [];
const badges = listing.display_badges ?? [];

// JSON-LD — limited info for off-market
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": listing.name,
  "description": description,
  "url": `https://staxre.com/off-market/${listing.slug}`,
  ...(listing.published_at && { "datePosted": listing.published_at }),
  "address": {
    "@type": "PostalAddress",
    "addressLocality": listing.city,
    "addressRegion": listing.state || "FL",
    "addressCountry": "US",
  },
  "broker": {
    "@type": "RealEstateAgent",
    "name": "STAX Real Estate",
    "url": "https://staxre.com",
    "telephone": "+1-321-770-0222",
  },
};
---

<BaseLayout title={title} description={description} ogImage={ogImage}>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumbs */}
  <section class="pt-[100px] pb-0 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <nav class="text-[13px] text-gray-500">
        <a href="/off-market" class="hover:text-red transition-colors">Off-Market</a>
        <span class="mx-2">/</span>
        <span class="text-black font-medium">{listing.name}</span>
      </nav>
    </div>
  </section>

  {/* Hero */}
  <section class="pt-8 pb-12 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">

      {/* Dark placeholder or image */}
      {listing.hero_image_url ? (
        <div class="w-full h-[400px] lg:h-[500px] overflow-hidden rounded-xl bg-gray-100">
          <img
            src={listing.hero_image_url}
            alt={`${listing.name} — ${listing.city}, ${listing.state}`}
            class="w-full h-full object-cover"
          />
        </div>
      ) : (
        <div class="w-full h-[300px] lg:h-[400px] overflow-hidden rounded-xl bg-gradient-to-br from-[#1a1e2e] via-[#2a2e3e] to-[#1a1e2e] flex items-center justify-center flex-col gap-4">
          <div class="w-16 h-16 border-2 border-white/15 rounded-full flex items-center justify-center text-white/30">
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
          </div>
          <span class="text-white/30 text-[12px] font-semibold tracking-[3px] uppercase">Confidential Listing</span>
        </div>
      )}

      {/* Badges */}
      {badges.length > 0 && (
        <div class="flex items-center gap-3 mt-8">
          {badges.map((badge) => (
            <span
              class="inline-block text-[10px] font-semibold px-3 py-1.5 rounded uppercase tracking-wider"
              style={`color: white; background-color: ${badge.color === "red" ? "#DA291C" : badge.color === "black" ? "#000" : badge.color}`}
            >
              {badge.text}
            </span>
          ))}
          <span class="inline-block text-[10px] font-semibold px-3 py-1.5 rounded uppercase tracking-wider bg-black/75 text-white">
            NDA Required
          </span>
        </div>
      )}

      <h1 class="font-heading text-3xl lg:text-[44px] leading-[1.15] font-semibold text-black mt-6 mb-4 tracking-tight">
        {listing.name}
      </h1>

      <p class="text-lg text-gray-500 mb-8">
        {[listing.city, listing.state].filter(Boolean).join(", ")}
        {listing.property_type ? ` — ${listing.property_type}` : ""}
      </p>
    </div>
  </section>

  {/* Content */}
  <section class="pb-16 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto lg:grid lg:grid-cols-[1fr_360px] lg:gap-16">

      {/* Left Column */}
      <div>
        {/* Key Metrics */}
        {displayMetrics.length > 0 && (
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 mb-12 pb-12 border-b border-gray-100">
            {displayMetrics.map((m, i) => (
              <div>
                <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-1">{m.label}</div>
                <div class:list={["font-heading text-3xl font-bold", i === 0 ? "text-red" : "text-black"]}>
                  {m.value}
                </div>
              </div>
            ))}
          </div>
        )}

        {/* Highlights */}
        {highlights.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-10">
            {highlights.map((h) => (
              <span class="text-[12px] font-medium text-gray-700 bg-gray-100 px-4 py-2 rounded-full">{h}</span>
            ))}
          </div>
        )}

        {/* Teaser Description */}
        {listing.website_description && (
          <div class="prose prose-lg max-w-none mb-12">
            <p class="text-[16px] leading-[1.8] text-gray-700 whitespace-pre-line">
              {listing.website_description}
            </p>
          </div>
        )}

        {/* Two CTAs: NDA (left) + Submit Offer (right) */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
          {/* NDA CTA Block */}
          <div class="bg-gray-50 rounded-xl p-8 text-center">
            <div class="w-12 h-12 border-2 border-gray-200 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
            </div>
            <h3 class="font-heading text-lg font-semibold text-black mb-2">Full Details Under NDA</h3>
            <p class="text-[14px] text-gray-600 leading-relaxed mb-5">
              Sign the NDA to access the dataroom with brief, supporting docs, and exact location.
            </p>
            <button
              class="inline-flex items-center justify-center gap-2 bg-red text-white px-6 py-3 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body w-full"
              onclick="openNDA()"
            >
              Request NDA Access
            </button>
          </div>

          {/* LOI Submission CTA */}
          <div class="bg-gray-50 rounded-xl p-8 text-center">
            <div class="w-12 h-12 border-2 border-gray-200 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="font-heading text-lg font-semibold text-black mb-2">Submit Your Offer</h3>
            <p class="text-[14px] text-gray-600 leading-relaxed mb-5">
              Send a non-binding LOI directly. We'll generate a STAX-letterhead document with your terms and review within 1–2 days.
            </p>
            <button
              class="inline-flex items-center justify-center gap-2 bg-black text-white px-6 py-3 rounded-md text-[14px] font-semibold hover:bg-gray-800 transition-colors border-none cursor-pointer font-body w-full"
              onclick="openLOI()"
            >
              Submit LOI
            </button>
          </div>
        </div>
      </div>

      {/* Right Column: Sidebar */}
      <div>
        <div class="bg-gray-50 rounded-xl p-8 mb-8 sticky top-[88px]">
          <h3 class="font-heading text-lg font-semibold text-black mb-6">Overview</h3>
          <dl class="space-y-4">
            <div class="flex justify-between">
              <dt class="text-sm text-gray-500">Location</dt>
              <dd class="text-sm font-medium text-black">{listing.city}, {listing.state || 'FL'}</dd>
            </div>
            {listing.property_type && (
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">Type</dt>
                <dd class="text-sm font-medium text-black">{listing.property_type}</dd>
              </div>
            )}
            {listing.brand && (
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">Brand</dt>
                <dd class="text-sm font-medium text-black">{listing.brand}</dd>
              </div>
            )}
            {listing.deal_type && (
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">Sale Type</dt>
                <dd class="text-sm font-medium text-black">{listing.deal_type}</dd>
              </div>
            )}
          </dl>

          <div class="mt-8 pt-6 border-t border-gray-200">
            <button
              onclick="openNDA()"
              class="block w-full text-center bg-red text-white py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body"
            >
              Unlock Full Details
            </button>
            <p class="text-center text-[12px] text-gray-500 mt-3">
              <a href="tel:+13217700222" class="text-red hover:underline">(321) 770-0222</a>
              &middot;
              <a href="mailto:michael@staxre.com" class="text-red hover:underline">michael@staxre.com</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Related */}
  {related.length > 0 && (
    <section class="py-20 px-6 lg:px-12 bg-gray-50">
      <div class="max-w-[1200px] mx-auto">
        <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-black mb-10">Other Off-Market Opportunities</h2>
        <div class="space-y-12">
          {related.map((r) => (
            <ListingCard listing={r} mode="off-market" />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="bg-gradient-to-br from-black to-[#1a1a2e] py-20 px-6 lg:px-12 text-center">
    <div class="max-w-[640px] mx-auto">
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-white mb-4">Have a station to sell?</h2>
      <p class="text-[17px] leading-relaxed text-white/60 mb-8">We represent sellers of gas stations, travel centers, and NNN-leased fuel assets across the Southeast. No upfront fees.</p>
      <a href="/sellers" class="inline-flex items-center gap-2.5 bg-red text-white px-9 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors">
        Schedule a Call
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  {/* NDA MODAL — same as /off-market index */}
  <div class="fixed inset-0 bg-black/50 z-[1000] items-center justify-center p-5 hidden" id="ndaModal" style="display: none;">
    <div class="bg-white rounded-xl max-w-[640px] w-full max-h-[90vh] overflow-y-auto relative shadow-2xl">
      <button class="absolute top-5 right-5 bg-transparent border-none text-gray-500 text-[28px] cursor-pointer leading-none p-1 hover:text-black" onclick="closeNDA()">&times;</button>
      <div class="px-8 pt-7 pb-5 border-b border-gray-100">
        <h2 class="font-heading text-2xl font-semibold text-black mb-2">Confidential Access Request</h2>
        <p class="text-sm text-gray-700 leading-relaxed">Complete the form and agree to our terms to receive the full property package for <strong>{listing.name}</strong>.</p>
      </div>
      <div class="px-8 py-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Full Name *</label>
            <input type="text" id="fullName" placeholder="John Smith" oninput="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Company</label>
            <input type="text" id="company" placeholder="Acme Investments LLC" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Email *</label>
            <input type="email" id="ndaEmail" placeholder="john@acmeinv.com" oninput="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Phone *</label>
            <input type="tel" id="phone" placeholder="(555) 123-4567" oninput="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Buyer Type *</label>
          <select id="buyerType" onchange="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors">
            <option value="">Select one...</option>
            <option value="principal">Principal Buyer (investing own capital)</option>
            <option value="broker">Broker / Agent (representing a buyer)</option>
            <option value="operator">Operator (looking to acquire &amp; operate)</option>
            <option value="investor">Passive Investor / 1031 Exchange</option>
            <option value="fund">Fund / Institutional</option>
          </select>
        </div>
        <div class="bg-gray-100 border border-gray-100 rounded-md p-5 max-h-[200px] overflow-y-auto text-[12px] leading-[1.7] text-gray-600 my-5">
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mb-1.5">Non-Disclosure and Confidentiality Agreement</h4>
          <p>By executing this agreement ("Agreement"), the undersigned ("Recipient") agrees to the following terms in connection with receiving confidential information regarding off-market commercial real estate opportunities presented by STAX Real Estate ("Broker").</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">1. Confidential Information</h4>
          <p>Recipient acknowledges that all property details, financial information, addresses, seller identities, lease terms, operating data, and related materials ("Confidential Information") provided by Broker are proprietary and confidential.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">2. Non-Disclosure</h4>
          <p>Recipient shall not disclose, distribute, reproduce, or share any Confidential Information with any third party without the prior written consent of Broker.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">3. Non-Circumvention</h4>
          <p>Recipient agrees not to directly or indirectly contact, negotiate with, or enter into any agreement with the property owner(s), seller(s), or their agents without the direct involvement of Broker. This obligation survives for twenty-four (24) months.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">4. Buyer Representative Commission</h4>
          <p>Recipient acknowledges that Broker shall be entitled to a buyer representative commission equal to two percent (2%) of the gross purchase price, due and payable at closing.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">5. Term and Governing Law</h4>
          <p>This Agreement shall remain in effect for 24 months. Governed by Florida law. Disputes resolved in Pinellas County, FL.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">6. Electronic Acceptance</h4>
          <p>Clicking "I Agree" and typing your name constitutes a legally binding electronic signature under the E-SIGN Act and UETA.</p>
        </div>
        <label class="flex items-start gap-2.5 mb-3.5 cursor-pointer">
          <input type="checkbox" id="agreeNDA" onchange="checkForm()" class="w-[18px] h-[18px] mt-0.5 accent-red shrink-0" />
          <span class="text-[13px] text-gray-800 leading-relaxed">I have read and agree to the Non-Disclosure Agreement, Non-Circumvention clause, and 2% Buyer Representative Commission terms above.</span>
        </label>
        <label class="flex items-start gap-2.5 mb-3.5 cursor-pointer">
          <input type="checkbox" id="agreeElectronic" onchange="checkForm()" class="w-[18px] h-[18px] mt-0.5 accent-red shrink-0" />
          <span class="text-[13px] text-gray-800 leading-relaxed">I consent to electronic execution of this agreement and understand this constitutes a binding legal commitment.</span>
        </label>
        <div class="mt-5 pt-4 border-t border-gray-100">
          <label class="block text-[13px] text-gray-600 mb-2">Type your full legal name as your electronic signature *</label>
          <input type="text" id="signature" placeholder="John Smith" oninput="checkForm()" class="w-full px-4 py-3.5 bg-white border border-black/8 rounded-md text-[22px] font-heading italic focus:outline-none focus:border-gray-300 transition-colors" />
        </div>
      </div>
      <div class="px-8 pb-7 pt-5">
        <button class="w-full py-3.5 bg-red text-white border-none rounded-md text-sm font-semibold cursor-pointer hover:bg-red-dark transition-colors disabled:opacity-35 disabled:cursor-not-allowed font-body" id="submitBtn" disabled onclick="submitNDA()">Unlock Property Details &rarr;</button>
        <p class="text-center text-[12px] text-gray-500 mt-3">A copy of your signed agreement will be emailed to you. Dataroom access is granted after review by our broker.</p>
      </div>
    </div>
  </div>

  <div class="fixed inset-0 bg-black/50 z-[1001] items-center justify-center hidden" id="successOverlay" style="display: none;">
    <div class="bg-white rounded-xl p-12 text-center max-w-[440px] shadow-2xl">
      <div class="w-14 h-14 bg-red-light rounded-full flex items-center justify-center mx-auto mb-5 text-red text-2xl">&#10003;</div>
      <h2 class="font-heading text-[28px] font-semibold text-black mb-3">NDA Received</h2>
      <p class="text-gray-600 text-[15px] mb-7 leading-relaxed">Your signed confidentiality agreement has been submitted. A confirmation has been sent to <strong id="successEmail">your email</strong>.</p>
      <p class="text-gray-500 text-[13px] mb-7 leading-relaxed">Your request is being reviewed. Once approved, you'll receive a secure link to the confidential dataroom with full property details, financials, and supporting documents.</p>
      <button class="inline-block px-7 py-3 bg-black text-white rounded-md font-semibold text-[13px] cursor-pointer border-none hover:bg-gray-800 transition-colors font-body" onclick="closeSuccess()">Back to Listings</button>
    </div>
  </div>

  {/* LOI MODAL — buyer fills in offer terms; backend generates STAX LOI */}
  <div class="fixed inset-0 bg-black/50 z-[1000] items-center justify-center p-5 hidden" id="loiModal" style="display: none;">
    <div class="bg-white rounded-xl max-w-[640px] w-full max-h-[92vh] overflow-y-auto relative shadow-2xl">
      <button class="absolute top-5 right-5 bg-transparent border-none text-gray-500 text-[28px] cursor-pointer leading-none p-1 hover:text-black" onclick="closeLOI()">&times;</button>
      <div class="px-8 pt-7 pb-5 border-b border-gray-100">
        <h2 class="font-heading text-2xl font-semibold text-black mb-2">Submit a Non-Binding LOI</h2>
        <p class="text-sm text-gray-700 leading-relaxed">Fill in your offer terms for <strong>{listing.name}</strong>. We'll generate a STAX-letterhead Letter of Intent with your terms and a 3% brokerage commission to STAX Real Estate. Michael will review within 1–2 business days and follow up directly.</p>
      </div>
      <div class="px-8 py-6">
        {/* Buyer info */}
        <div class="text-[11px] font-semibold tracking-[1px] uppercase text-gray-500 mb-3">Buyer</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Full Name *</label>
            <input type="text" id="loiBuyerName" placeholder="John Smith" oninput="checkLOIForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Title</label>
            <input type="text" id="loiBuyerTitle" placeholder="Manager / Principal" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Buyer Entity / LLC</label>
            <input type="text" id="loiBuyerEntity" placeholder="Acme Investments LLC" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Phone</label>
            <input type="tel" id="loiBuyerPhone" placeholder="(555) 123-4567" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="mb-5">
          <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Email *</label>
          <input type="email" id="loiBuyerEmail" placeholder="john@acmeinv.com" oninput="checkLOIForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
        </div>

        {/* Offer terms */}
        <div class="text-[11px] font-semibold tracking-[1px] uppercase text-gray-500 mb-3">Offer Terms</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Purchase Price *</label>
            <input type="number" id="loiPrice" placeholder="1500000" oninput="checkLOIForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Earnest Money *</label>
            <input type="number" id="loiEarnest" placeholder="50000" oninput="checkLOIForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Inspection Period (days)</label>
            <input type="number" id="loiInspectionDays" value="30" min="1" max="120" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Days to Close (post-inspection)</label>
            <input type="number" id="loiClosingDays" value="30" min="1" max="120" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 mb-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="loiFinancing" class="w-[16px] h-[16px] accent-red" />
            <span class="text-[13px] text-gray-800">Financing contingency</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="loi1031" class="w-[16px] h-[16px] accent-red" />
            <span class="text-[13px] text-gray-800">1031 exchange</span>
          </label>
        </div>
        <div class="mb-4">
          <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Additional Terms (optional)</label>
          <textarea id="loiAdditionalTerms" rows="3" placeholder="Any other terms, contingencies, or notes..." class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[14px] focus:outline-none focus:border-gray-300 transition-colors resize-none"></textarea>
        </div>

        {/* Commission notice */}
        <div class="bg-gray-100 border border-gray-200 rounded-md p-4 text-[12px] leading-relaxed text-gray-700 mb-4">
          <strong>Commission:</strong> The generated LOI includes a 3% brokerage commission payable by the Seller to STAX Real Estate LLC at close of escrow. No other brokers will be entitled to commission on this transaction.
        </div>
      </div>
      <div class="px-8 pb-7 pt-2">
        <button class="w-full py-3.5 bg-red text-white border-none rounded-md text-sm font-semibold cursor-pointer hover:bg-red-dark transition-colors disabled:opacity-35 disabled:cursor-not-allowed font-body" id="loiSubmitBtn" disabled onclick="submitLOI()">Generate &amp; Submit LOI &rarr;</button>
        <p class="text-center text-[12px] text-gray-500 mt-3">Non-binding — Michael will review and follow up via email within 1–2 business days.</p>
      </div>
    </div>
  </div>

  {/* LOI SUCCESS OVERLAY */}
  <div class="fixed inset-0 bg-black/50 z-[1001] items-center justify-center hidden" id="loiSuccessOverlay" style="display: none;">
    <div class="bg-white rounded-xl p-12 text-center max-w-[440px] shadow-2xl">
      <div class="w-14 h-14 bg-red-light rounded-full flex items-center justify-center mx-auto mb-5 text-red text-2xl">&#10003;</div>
      <h2 class="font-heading text-[28px] font-semibold text-black mb-3">Offer Received</h2>
      <p class="text-gray-600 text-[15px] mb-7 leading-relaxed">Your Letter of Intent has been generated and forwarded to Michael Salafia for review. A confirmation has been sent to <strong id="loiSuccessEmail">your email</strong>.</p>
      <p class="text-gray-500 text-[13px] mb-7 leading-relaxed">You'll hear back within 1–2 business days. Michael will either counter-sign the LOI or reach out with revised terms.</p>
      <button class="inline-block px-7 py-3 bg-black text-white rounded-md font-semibold text-[13px] cursor-pointer border-none hover:bg-gray-800 transition-colors font-body" onclick="closeLOISuccess()">Back to Listing</button>
    </div>
  </div>

  <script is:inline define:vars={{ listingSlug: listing.slug, listingName: listing.name }}>
    function openNDA() {
      var modal = document.getElementById('ndaModal');
      modal.style.display = 'flex';
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeNDA() {
      var modal = document.getElementById('ndaModal');
      modal.style.display = 'none';
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function checkForm() {
      var name = document.getElementById('fullName').value.trim();
      var email = document.getElementById('ndaEmail').value.trim();
      var phone = document.getElementById('phone').value.trim();
      var buyerType = document.getElementById('buyerType').value;
      var agreeNDA = document.getElementById('agreeNDA').checked;
      var agreeElectronic = document.getElementById('agreeElectronic').checked;
      var signature = document.getElementById('signature').value.trim();
      var valid = name && email && phone && buyerType && agreeNDA && agreeElectronic && signature;
      document.getElementById('submitBtn').disabled = !valid;
    }

    function submitNDA() {
      var btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Submitting...';

      var email = document.getElementById('ndaEmail').value.trim();
      var leadData = {
        property: listingSlug,
        propertyTitle: listingName,
        name: document.getElementById('fullName').value,
        email: email,
        phone: document.getElementById('phone').value,
        company: document.getElementById('company').value,
        buyerType: document.getElementById('buyerType').value,
        signature: document.getElementById('signature').value,
        timestamp: new Date().toISOString()
      };

      fetch('/api/off-market-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(leadData)
      }).then(function() {
        document.getElementById('successEmail').textContent = email;
        closeNDA();
        var overlay = document.getElementById('successOverlay');
        overlay.style.display = 'flex';
        overlay.classList.remove('hidden');
      }).catch(function(err) {
        console.error('Submit error:', err);
        document.getElementById('successEmail').textContent = email;
        closeNDA();
        var overlay = document.getElementById('successOverlay');
        overlay.style.display = 'flex';
        overlay.classList.remove('hidden');
      }).finally(function() {
        btn.disabled = false;
        btn.innerHTML = 'Unlock Property Details &rarr;';
      });
    }

    function closeSuccess() {
      var overlay = document.getElementById('successOverlay');
      overlay.style.display = 'none';
      overlay.classList.add('hidden');
      document.querySelectorAll('#ndaModal input, #ndaModal select').forEach(function(el) {
        if (el.type === 'checkbox') el.checked = false;
        else el.value = '';
      });
      document.getElementById('submitBtn').disabled = true;
    }

    /* ─── LOI Modal ─────────────────────────────────────────────────── */
    function openLOI() {
      var modal = document.getElementById('loiModal');
      modal.style.display = 'flex';
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeLOI() {
      var modal = document.getElementById('loiModal');
      modal.style.display = 'none';
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function checkLOIForm() {
      var name = document.getElementById('loiBuyerName').value.trim();
      var email = document.getElementById('loiBuyerEmail').value.trim();
      var price = parseFloat(document.getElementById('loiPrice').value);
      var earnest = parseFloat(document.getElementById('loiEarnest').value);
      var valid = name && email && price > 0 && earnest > 0;
      document.getElementById('loiSubmitBtn').disabled = !valid;
    }

    function submitLOI() {
      var btn = document.getElementById('loiSubmitBtn');
      btn.disabled = true;
      btn.textContent = 'Submitting...';

      var email = document.getElementById('loiBuyerEmail').value.trim();
      var payload = {
        slug: listingSlug,
        buyer_name: document.getElementById('loiBuyerName').value.trim(),
        buyer_email: email,
        buyer_entity: document.getElementById('loiBuyerEntity').value.trim() || null,
        buyer_title: document.getElementById('loiBuyerTitle').value.trim() || null,
        buyer_phone: document.getElementById('loiBuyerPhone').value.trim() || null,
        purchase_price: parseFloat(document.getElementById('loiPrice').value) || 0,
        earnest_money: parseFloat(document.getElementById('loiEarnest').value) || 0,
        inspection_days: parseInt(document.getElementById('loiInspectionDays').value || '30', 10),
        closing_days: parseInt(document.getElementById('loiClosingDays').value || '30', 10),
        financing_contingency: document.getElementById('loiFinancing').checked,
        is_1031_exchange: document.getElementById('loi1031').checked,
        additional_terms: document.getElementById('loiAdditionalTerms').value.trim() || null,
      };

      fetch('/api/submit-loi', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(function(r) {
        return r.json().then(function(data) { return { ok: r.ok, data: data }; });
      }).then(function(res) {
        if (!res.ok) {
          var msg = (res.data && res.data.error) ? res.data.error : 'Submission failed.';
          alert('Could not submit your LOI: ' + msg + '\n\nPlease email michael@staxre.com directly.');
          btn.disabled = false;
          btn.innerHTML = 'Generate & Submit LOI &rarr;';
          return;
        }
        document.getElementById('loiSuccessEmail').textContent = email;
        closeLOI();
        var overlay = document.getElementById('loiSuccessOverlay');
        overlay.style.display = 'flex';
        overlay.classList.remove('hidden');
        // Reset form for next time
        document.querySelectorAll('#loiModal input').forEach(function(el) {
          if (el.type === 'checkbox') el.checked = false;
          else if (el.id === 'loiInspectionDays' || el.id === 'loiClosingDays') el.value = '30';
          else el.value = '';
        });
        document.getElementById('loiAdditionalTerms').value = '';
        btn.disabled = true;
        btn.innerHTML = 'Generate & Submit LOI &rarr;';
      }).catch(function(err) {
        console.error('LOI submit error:', err);
        alert('Network error — please try again or email michael@staxre.com directly.');
        btn.disabled = false;
        btn.innerHTML = 'Generate & Submit LOI &rarr;';
      });
    }

    function closeLOISuccess() {
      var overlay = document.getElementById('loiSuccessOverlay');
      overlay.style.display = 'none';
      overlay.classList.add('hidden');
    }
  </script>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Off-Market", "item": "https://staxre.com/off-market" },
      { "@type": "ListItem", "position": 2, "name": listing.name, "item": `https://staxre.com/off-market/${listing.slug}` },
    ],
  })} />

</BaseLayout>
