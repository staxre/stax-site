---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About STAX Real Estate — The Operator-Broker" description="STAX founder Michael Salafia served as CEO of a dozen-location gas station operating company. 180+ stations sold, $525M+ in transaction volume. The only brokerage built by someone who has lived the P&L.">

  <!-- HERO -->
  <section class="pt-[140px] pb-[80px] px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">About STAX</div>
      <h1 class="font-heading text-4xl lg:text-[52px] leading-[1.12] font-semibold text-black mb-6 tracking-tight max-w-[900px]">
        The Only NNN Broker Who's Run the Business.
      </h1>
      <p class="text-lg leading-relaxed text-gray-700 mb-9 max-w-[600px]">
        STAX was built on a simple idea: the best gas station broker is someone who's actually owned and operated the business. Not from a brokerage desk — from the CEO seat of a multi-location operating company. That changes everything about how we value properties, spot risk, and close deals.
      </p>
    </div>
  </section>

  <!-- MICHAEL'S STORY -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <span class="inline-block text-[11px] font-semibold tracking-[2px] uppercase text-red bg-red-light px-3.5 py-1.5 rounded mb-5">
          Founder
        </span>
        <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-6 tracking-tight leading-snug">
          From Gas Station CEO to Principal Broker
        </h2>
        <p class="text-[17px] leading-relaxed text-gray-700 mb-6">
          Michael Salafia didn't start in a brokerage office. He served as CEO of a gas station operating company — overseeing a dozen locations with c-stores. He knows every detail of the business because he ran the business.
        </p>
        <p class="text-[17px] leading-relaxed text-gray-700 mb-6">
          That experience became STAX's foundation. When Michael evaluates a deal, he looks at it the way an operator would — not just the cap rate on a spreadsheet.
        </p>
        <p class="text-[17px] leading-relaxed text-gray-700 mb-8">
          Today, STAX is the bridge between two worlds that nobody else connects: gas station operators who need a broker that understands their business, and NNN investors looking for the most tax-advantaged asset class in commercial real estate.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2.5 bg-red text-white px-8 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors tracking-wide">
          Schedule a Conversation
          <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="relative h-[400px] lg:h-[480px] rounded-xl overflow-hidden bg-gray-100">
        <img src="/images/michael-headshot.png" alt="Michael Salafia - Founder & Principal Broker" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- TRACK RECORD -->
  <section class="py-24 px-6 lg:px-12 bg-gray-100">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Track Record</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">The numbers behind the operator advantage</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="bg-white rounded-xl p-8 border border-black/8">
          <div class="font-heading text-[44px] font-bold text-red mb-3">180+</div>
          <div class="text-[13px] text-gray-500 uppercase tracking-wider font-semibold">Gas Stations & C-Stores Sold</div>
          <p class="text-[15px] leading-relaxed text-gray-700 mt-4">Individual transactions across branded and independent stations, c-stores, and fuel retail operations.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-black/8">
          <div class="font-heading text-[44px] font-bold text-red mb-3">$525M+</div>
          <div class="text-[13px] text-gray-500 uppercase tracking-wider font-semibold">Transaction Volume</div>
          <p class="text-[15px] leading-relaxed text-gray-700 mt-4">Cumulative sales across gas stations, QSRs, and diversified NNN investment properties.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-black/8">
          <div class="font-heading text-[44px] font-bold text-red mb-3">$2B+</div>
          <div class="text-[13px] text-gray-500 uppercase tracking-wider font-semibold">Aggregate Lease Value</div>
          <p class="text-[15px] leading-relaxed text-gray-700 mt-4">Net present value of leases in advisory portfolios across income-tax-free states.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT MAKES STAX DIFFERENT -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">What Makes Us Different</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">Four things no other brokerage offers</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div class="border border-black/8 rounded-xl p-10 bg-white hover:shadow-lg transition-all">
          <div class="text-red font-heading text-3xl font-bold mb-3">01</div>
          <h3 class="font-heading text-xl font-semibold text-black mb-3">Operator Experience</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">We've owned and operated a dozen gas stations with c-stores. We know every detail because we ran the business. That changes how we evaluate every deal.</p>
        </div>
        <div class="border border-black/8 rounded-xl p-10 bg-white hover:shadow-lg transition-all">
          <div class="text-red font-heading text-3xl font-bold mb-3">02</div>
          <h3 class="font-heading text-xl font-semibold text-black mb-3">Dual Network</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">We sell stations to operators AND structure NNN deals for passive investors. That dual buyer pool means sellers get better prices, and investors get access to off-market operator deals.</p>
        </div>
        <div class="border border-black/8 rounded-xl p-10 bg-white hover:shadow-lg transition-all">
          <div class="text-red font-heading text-3xl font-bold mb-3">03</div>
          <h3 class="font-heading text-xl font-semibold text-black mb-3">Principal Access</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">No associates, no handoffs, no transaction coordinators. The person who takes your call is the person who closes your deal. For $2M–$10M deals, that principal attention matters enormously.</p>
        </div>
        <div class="border border-black/8 rounded-xl p-10 bg-white hover:shadow-lg transition-all">
          <div class="text-red font-heading text-3xl font-bold mb-3">04</div>
          <h3 class="font-heading text-xl font-semibold text-black mb-3">Tax Strategy Built In</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">Bonus depreciation, cost segregation, 1031 exchanges — we don't just know the terms, we structure deals around them. The tax play isn't an afterthought at STAX. It's part of the deal from day one.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOCUS MARKETS -->
  <section class="py-24 px-6 lg:px-12 bg-gray-100">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Primary Markets</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">Income-tax-free states with strong gas station fundamentals</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
        <div class="bg-white rounded-xl p-8 border border-black/8 hover:border-red hover:shadow-lg transition-all text-center">
          <h3 class="font-heading text-xl font-semibold text-black mb-2">Florida</h3>
          <p class="text-[14px] text-gray-700">Home base. No state income tax. Strong tourism, population growth, and diverse gas station markets from Miami to Jacksonville.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-black/8 hover:border-red hover:shadow-lg transition-all text-center">
          <h3 class="font-heading text-xl font-semibold text-black mb-2">Texas</h3>
          <p class="text-[14px] text-gray-700">No state income tax. Energy sector, commercial expansion, and high-volume gas station corridors from Houston to Dallas.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-black/8 hover:border-red hover:shadow-lg transition-all text-center">
          <h3 class="font-heading text-xl font-semibold text-black mb-2">Nevada</h3>
          <p class="text-[14px] text-gray-700">No state income tax. Las Vegas metro growth, highway corridor opportunities, and strong QSR fundamentals.</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-black/8 hover:border-red hover:shadow-lg transition-all text-center">
          <h3 class="font-heading text-xl font-semibold text-black mb-2">Tennessee</h3>
          <p class="text-[14px] text-gray-700">No state income tax. Growing Nashville, Memphis, and Knoxville markets with emerging investor interest.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AS SEEN ON -->
  <section class="py-14 px-6 lg:px-12 border-y border-gray-100">
    <div class="max-w-[1200px] mx-auto text-center">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-gray-500 mb-7">Featured In</div>
      <div class="flex items-center justify-center gap-10 lg:gap-12 flex-wrap opacity-40">
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">C-Store Dive</span>
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">Real Deal</span>
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">NAOIP</span>
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">ReFuel Forum</span>
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">Shrimp Tank</span>
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">Agora</span>
        <span class="text-[15px] font-semibold text-gray-900 tracking-wide">CCR Magazine</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-black to-[#1a1a2e] py-20 px-6 lg:px-12 text-center">
    <div class="max-w-[640px] mx-auto">
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-white mb-4">Ready to work with an operator-broker?</h2>
      <p class="text-[17px] leading-relaxed text-white/60 mb-8">Let's talk about your goals. No pitch, no pressure — just a conversation between principals.</p>
      <a href="/contact" class="inline-flex items-center gap-2.5 bg-red text-white px-9 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors">
        Schedule a Call
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

</BaseLayout>
