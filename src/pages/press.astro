  <section class="py-20 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Thought Leadership</div>
      <h2 class="font-heading text-3xl lg:text-[36px] font-semibold text-black mb-10 tracking-tight leading-snug">
        Published articles & contributed expertise
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- NAIOP -->
        <a href="https://www.naiop.org/research-and-publications/magazine/2024/spring-2024/marketing-leasing/strategic-approaches-to-mastering-triple-net-lease-properties/" target="_blank" rel="noopener" class="group border border-black/8 rounded-xl p-8 bg-white hover:border-red hover:shadow-lg transition-all">
          <div class="flex items-start justify-between gap-4 mb-4">
            <span class="inline-block text-[10px] font-bold tracking-wider uppercase bg-red-light text-red px-2.5 py-1 rounded">Print + Online</span>
            <span class="text-[12px] text-gray-400 font-medium shrink-0">Spring 2024</span>
