---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Press & Media — STAX Real Estate" description="STAX Real Estate in the news. Featured in NAIOP, The Verge, The Real Deal, Bisnow, Yahoo Finance, C-Store Dive, and 70+ media placements across CRE, energy, and tech.">

  <!-- HERO -->
  <section class="pt-[140px] pb-16 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <span class="inline-block text-[11px] font-semibold tracking-[2px] uppercase text-red bg-red-light px-3.5 py-1.5 rounded mb-5">
        Press & Media
      </span>
      <h1 class="font-heading text-4xl lg:text-[52px] leading-[1.12] font-semibold text-black mb-6 tracking-tight max-w-[800px]">
        In the News
      </h1>
      <p class="text-lg leading-relaxed text-gray-700 max-w-[640px]">
        STAX founder Michael Salafia is a recognized voice in gas station brokerage, NNN investing, and the future of convenience retail. From NAIOP Development Magazine to The Verge, here's where we've been featured.
      </p>
    </div>
  </section>

  <!-- AS FEATURED IN — LOGO BAR -->
  <section class="py-12 px-6 lg:px-12 border-y border-gray-100 bg-gray-50">
    <div class="max-w-[1200px] mx-auto text-center">
      <div class="text-[10px] font-semibold tracking-[2px] uppercase text-gray-400 mb-6">Featured In</div>
      <div class="flex items-center justify-center gap-8 lg:gap-10 flex-wrap opacity-50">
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">NAIOP</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">The Verge</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">The Real Deal</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">Bisnow</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">Yahoo Finance</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">C-Store Dive</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">MarketWatch</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">CCR Magazine</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">SFBW</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">SFBJ</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">Florida Trend</span>
        <span class="text-[15px] font-bold text-gray-900 tracking-wide">Authority Magazine</span>
      </div>
    </div>
  </section>

