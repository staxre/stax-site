---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Off-Market Opportunities — Gas Stations & Travel Centers | STAX Real Estate" description="Exclusive off-market gas stations, travel centers, and net-lease investments not listed on public marketplaces. Sign our NDA to unlock full property details.">

  <!-- HERO -->
  <section class="pt-[140px] pb-[60px] px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="inline-block bg-red-light text-red text-[11px] font-semibold tracking-[2px] uppercase px-2.5 py-1 rounded mb-6">Off-Market Inventory</div>
      <h1 class="font-heading text-4xl lg:text-[52px] leading-[1.12] font-semibold text-black mb-6 tracking-tight max-w-[900px]">
        Off-Market Opportunities
      </h1>
      <p class="text-lg leading-relaxed text-gray-700 max-w-[600px]">
        Gas stations, travel centers, and net-lease investments not available on public marketplaces. Sign our confidentiality agreement to unlock full property details.
      </p>
    </div>
  </section>

  <!-- LISTING CARDS -->
  <section class="pb-24 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto space-y-12">

      <!-- CARD 1: South Florida 11-Site Portfolio -->
      <div class="flex flex-col lg:flex-row rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all cursor-pointer" onclick="openNDA('soflo11', 'South Florida 11-Site Portfolio')">
        <div class="w-full lg:w-[440px] h-[300px] lg:h-auto shrink-0 relative overflow-hidden bg-gradient-to-br from-[#1a1e2e] via-[#2a2e3e] to-[#1a1e2e] flex items-center justify-center flex-col gap-2">
          <span class="absolute top-4 left-4 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Portfolio</span>
          <span class="absolute top-4 right-4 bg-black/75 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">NDA Required</span>
          <div class="w-12 h-12 border-2 border-white/15 rounded-full flex items-center justify-center text-white/30">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <span class="text-white/25 text-[11px] font-semibold tracking-[2px] uppercase">11 Stations &middot; Confidential</span>
        </div>
        <div class="p-10 flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block text-[10px] font-semibold text-white bg-red px-2.5 py-1 rounded">Multi-Brand</span>
            <span class="inline-block text-[10px] font-semibold text-red bg-red-light px-2.5 py-1 rounded">Owner-Operator</span>
          </div>
          <h3 class="font-heading text-2xl lg:text-[28px] font-semibold text-black mb-4">South Florida 11-Site Portfolio</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-4">
            Institutional-scale portfolio of 11 branded gas stations with convenience stores across South Florida's highest-traffic corridors. Six major fuel brands represented. 2025 net profit of $13.7M across 13.2M gallons and $19.7M total income. Private sale of active businesses.
          </p>
          <p class="text-sm text-gray-500 mb-6">Palm Beach, Broward &amp; Miami-Dade Counties &middot; Exxon, Shell, BP, Chevron, Mobil, Sunoco</p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-6">
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Total Income</div>
              <div class="font-heading text-2xl font-bold text-black">$19.7M</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Net Profit</div>
              <div class="font-heading text-2xl font-bold text-black">$13.7M</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Fuel Volume</div>
              <div class="font-heading text-2xl font-bold text-black">13.2M gal</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">C-Store Sales</div>
              <div class="font-heading text-2xl font-bold text-red">$17.3M</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">South Florida</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">6 Major Brands</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Portfolio Sale</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Active Operations</span>
          </div>

          <button class="inline-flex items-center gap-2.5 bg-red text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Unlock Full Details &rarr;
          </button>
        </div>
      </div>

      <!-- CARD 2: Miami 2-Site Portfolio -->
      <div class="flex flex-col lg:flex-row rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all cursor-pointer" onclick="openNDA('miami2', '2-Station Portfolio — Miami, FL')">
        <div class="w-full lg:w-[440px] h-[300px] lg:h-auto shrink-0 bg-gray-100 relative overflow-hidden">
          <img src="/images/miami-portfolio-rendering.jpg" alt="Gas Station Portfolio — Miami, FL" class="w-full h-full object-cover" />
          <span class="absolute top-4 left-4 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Portfolio</span>
          <span class="absolute top-4 right-4 bg-black/75 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">NDA Required</span>
        </div>
        <div class="p-10 flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block text-[10px] font-semibold text-white bg-red px-2.5 py-1 rounded">Unbranded</span>
            <span class="inline-block text-[10px] font-semibold text-red bg-red-light px-2.5 py-1 rounded">Owner-Operator</span>
          </div>
          <h3 class="font-heading text-2xl lg:text-[28px] font-semibold text-black mb-4">2-Station Portfolio &mdash; Miami, FL</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-4">
            Two gas station properties in the heart of Miami-Dade County offered as a portfolio sale. No fuel supply agreement &mdash; buyer has full flexibility to rebrand, re-lease, or owner-operate from day one. Existing tenant vacating upon sale. Fully built-out with canopies, tanks, and c-stores.
          </p>
          <p class="text-sm text-gray-500 mb-6">Miami-Dade County &middot; 2 Sites &middot; Unbranded &middot; No Fuel Contract</p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-6">
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Asking Price</div>
              <div class="font-heading text-2xl font-bold text-black">$11.5M</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Sites</div>
              <div class="font-heading text-2xl font-bold text-black">2</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Structure</div>
              <div class="font-heading text-2xl font-bold text-black">Fee Simple</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Availability</div>
              <div class="font-heading text-2xl font-bold text-red">Immediate</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Miami-Dade</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Motivated Seller</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Repositioning Upside</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">No Fuel Contract</span>
          </div>

          <button class="inline-flex items-center gap-2.5 bg-red text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Unlock Full Details &rarr;
          </button>
        </div>
      </div>

      <!-- CARD 3: Port St. Lucie C-Store & Gas -->
      <div class="flex flex-col lg:flex-row rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all cursor-pointer" onclick="openNDA('psl', 'C-Store &amp; Gas — Port St. Lucie, FL')">
        <div class="w-full lg:w-[440px] h-[300px] lg:h-auto shrink-0 relative overflow-hidden bg-gradient-to-br from-[#1a1e2e] via-[#2a2e3e] to-[#1a1e2e] flex items-center justify-center flex-col gap-2">
          <span class="absolute top-4 left-4 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Business Sale</span>
          <span class="absolute top-4 right-4 bg-black/75 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">NDA Required</span>
          <div class="w-12 h-12 border-2 border-white/15 rounded-full flex items-center justify-center text-white/30">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <span class="text-white/25 text-[11px] font-semibold tracking-[2px] uppercase">Port St. Lucie &middot; Confidential</span>
        </div>
        <div class="p-10 flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block text-[10px] font-semibold text-white bg-red px-2.5 py-1 rounded">Branded</span>
            <span class="inline-block text-[10px] font-semibold text-red bg-red-light px-2.5 py-1 rounded">Asset Sale + NNN Lease</span>
          </div>
          <h3 class="font-heading text-2xl lg:text-[28px] font-semibold text-black mb-4">C-Store &amp; Gas &mdash; Port St. Lucie, FL</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-4">
            Established neighborhood convenience store and gas station on the Treasure Coast with nearly $3M in annual merchandise sales and consistent fuel volume. Asset sale with long-term NNN lease in place. Proven operating history with strong gross profit margins.
          </p>
          <p class="text-sm text-gray-500 mb-6">St. Lucie County &middot; Branded &middot; Business Sale &middot; $20K/mo NNN Lease</p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-6">
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Asking Price</div>
              <div class="font-heading text-2xl font-bold text-black">$1.9M</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Gross Sales</div>
              <div class="font-heading text-2xl font-bold text-black">$6.2M/yr</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Fuel Volume</div>
              <div class="font-heading text-2xl font-bold text-black">981K gal</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">EBITDA</div>
              <div class="font-heading text-2xl font-bold text-red">$550K</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Treasure Coast</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">$3M Inside Sales</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">NNN Lease</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Established Operations</span>
          </div>

          <button class="inline-flex items-center gap-2.5 bg-red text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Unlock Full Details &rarr;
          </button>
        </div>
      </div>

      <!-- CARD 4: Booneville Travel Center -->
      <div class="flex flex-col lg:flex-row rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all cursor-pointer" onclick="openNDA('booneville', 'Travel Center — Booneville, MS')">
        <div class="w-full lg:w-[440px] h-[300px] lg:h-auto shrink-0 relative overflow-hidden bg-gradient-to-br from-[#1a1e2e] via-[#2a2e3e] to-[#1a1e2e] flex items-center justify-center flex-col gap-2">
          <span class="absolute top-4 left-4 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Owner-User</span>
          <span class="absolute top-4 right-4 bg-black/75 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">NDA Required</span>
          <div class="w-12 h-12 border-2 border-white/15 rounded-full flex items-center justify-center text-white/30">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <span class="text-white/25 text-[11px] font-semibold tracking-[2px] uppercase">Booneville, MS &middot; Confidential</span>
        </div>
        <div class="p-10 flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block text-[10px] font-semibold text-white bg-red px-2.5 py-1 rounded">Exxon Branded</span>
            <span class="inline-block text-[10px] font-semibold text-red bg-red-light px-2.5 py-1 rounded">Travel Center</span>
          </div>
          <h3 class="font-heading text-2xl lg:text-[28px] font-semibold text-black mb-4">Travel Center &mdash; Booneville, MS</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-4">
            High-volume Exxon travel center on a major interstate corridor in Northeast Mississippi. Built in 2023 on nearly 17 acres with 12 fueling positions including 5 diesel lanes. On-site QSR, beer cave, showers, and room for additional revenue streams.
          </p>
          <p class="text-sm text-gray-500 mb-6">Northeast MS &middot; 6,050 SF &middot; 16.93 AC &middot; Exxon Branded &middot; I-22 Corridor</p>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-6">
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Asking Price</div>
              <div class="font-heading text-2xl font-bold text-black">$13M</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Fuel Volume</div>
              <div class="font-heading text-2xl font-bold text-black">2.1M gal/yr</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Inside Sales</div>
              <div class="font-heading text-2xl font-bold text-black">$2.3M/yr</div>
            </div>
            <div>
              <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Net Income</div>
              <div class="font-heading text-2xl font-bold text-red">$1.38M</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 mb-6">
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">I-22 Corridor</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">Built 2023</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">12 Fueling Positions</span>
            <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">QSR On-Site</span>
          </div>

          <button class="inline-flex items-center gap-2.5 bg-red text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Unlock Full Details &rarr;
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- DEAL ALERTS SIGNUP -->
  <section class="py-24 px-6 lg:px-12 bg-gray-100">
    <div class="max-w-[700px] mx-auto text-center">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Deal Alerts</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-4 tracking-tight leading-snug">
        Get first look at new deals
      </h2>
      <p class="text-[17px] leading-relaxed text-gray-700 mb-10">
        Off-market opportunities, new listings, and portfolio sales &mdash; including full financials, lease terms, and depreciation analysis. Direct to your inbox.
      </p>
      <form class="flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); submitDealAlert();">
        <input
          type="email"
          id="alertEmail"
          placeholder="your@email.com"
          class="flex-1 px-5 py-4 rounded-md border border-black/8 text-[15px] focus:outline-none focus:border-red transition-colors"
          required
        />
        <button type="submit" class="bg-red text-white px-8 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors whitespace-nowrap cursor-pointer border-none font-body">
          Get Deal Alerts
        </button>
      </form>
      <p class="text-[13px] text-gray-600 mt-4">Matching deals only. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- DARK CTA: Seller -->
  <section class="bg-gradient-to-br from-black to-[#1a1a2e] py-20 px-6 lg:px-12 text-center">
    <div class="max-w-[640px] mx-auto">
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-white mb-4">Have a station to sell?</h2>
      <p class="text-[17px] leading-relaxed text-white/60 mb-8">We represent sellers of gas stations, travel centers, and NNN-leased fuel assets across the Southeast. No upfront fees.</p>
      <a href="/sellers" class="inline-flex items-center gap-2.5 bg-red text-white px-9 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors">
        Schedule a Call
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- NDA MODAL -->
  <div class="fixed inset-0 bg-black/50 z-[1000] items-center justify-center p-5 hidden" id="ndaModal" style="display: none;">
    <div class="bg-white rounded-xl max-w-[640px] w-full max-h-[90vh] overflow-y-auto relative shadow-2xl">
      <button class="absolute top-5 right-5 bg-transparent border-none text-gray-500 text-[28px] cursor-pointer leading-none p-1 hover:text-black" onclick="closeNDA()">&times;</button>
      <div class="px-8 pt-7 pb-5 border-b border-gray-100">
        <h2 class="font-heading text-2xl font-semibold text-black mb-2">Confidential Access Request</h2>
        <p class="text-sm text-gray-700 leading-relaxed">Complete the form and agree to our terms to receive the full property package including address, financials, and offering memorandum for <strong id="modalPropertyName"></strong>.</p>
      </div>
      <div class="px-8 py-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Full Name *</label>
            <input type="text" id="fullName" placeholder="John Smith" oninput="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Company</label>
            <input type="text" id="company" placeholder="Acme Investments LLC" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Email *</label>
            <input type="email" id="ndaEmail" placeholder="john@acmeinv.com" oninput="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Phone *</label>
            <input type="tel" id="phone" placeholder="(555) 123-4567" oninput="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors" />
          </div>
        </div>
        <div class="mb-4">
          <label class="block text-[13px] font-medium text-gray-600 mb-1.5">Buyer Type *</label>
          <select id="buyerType" onchange="checkForm()" class="w-full px-4 py-3 bg-white border border-black/8 rounded-md text-[15px] focus:outline-none focus:border-gray-300 transition-colors">
            <option value="">Select one...</option>
            <option value="principal">Principal Buyer (investing own capital)</option>
            <option value="broker">Broker / Agent (representing a buyer)</option>
            <option value="operator">Operator (looking to acquire &amp; operate)</option>
            <option value="investor">Passive Investor / 1031 Exchange</option>
            <option value="fund">Fund / Institutional</option>
          </select>
        </div>

        <!-- NDA Text Box -->
        <div class="bg-gray-100 border border-gray-100 rounded-md p-5 max-h-[200px] overflow-y-auto text-[12px] leading-[1.7] text-gray-600 my-5">
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mb-1.5">Non-Disclosure and Confidentiality Agreement</h4>
          <p>By executing this agreement ("Agreement"), the undersigned ("Recipient") agrees to the following terms in connection with receiving confidential information regarding off-market commercial real estate opportunities presented by STAX Real Estate ("Broker").</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">1. Confidential Information</h4>
          <p>Recipient acknowledges that all property details, financial information, addresses, seller identities, lease terms, operating data, and related materials ("Confidential Information") provided by Broker are proprietary and confidential.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">2. Non-Disclosure</h4>
          <p>Recipient shall not disclose, distribute, reproduce, or share any Confidential Information with any third party without the prior written consent of Broker.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">3. Non-Circumvention</h4>
          <p>Recipient agrees not to directly or indirectly contact, negotiate with, or enter into any agreement with the property owner(s), seller(s), or their agents without the direct involvement of Broker. This obligation survives for twenty-four (24) months.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">4. Buyer Representative Commission</h4>
          <p>Recipient acknowledges that Broker shall be entitled to a buyer representative commission equal to two percent (2%) of the gross purchase price, due and payable at closing.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">5. Term and Governing Law</h4>
          <p>This Agreement shall remain in effect for 24 months. Governed by Florida law. Disputes resolved in Pinellas County, FL.</p>
          <h4 class="text-black text-[12px] font-bold uppercase tracking-wide mt-3.5 mb-1.5">6. Electronic Acceptance</h4>
          <p>Clicking "I Agree" and typing your name constitutes a legally binding electronic signature under the E-SIGN Act and UETA.</p>
        </div>

        <!-- Checkboxes -->
        <label class="flex items-start gap-2.5 mb-3.5 cursor-pointer">
          <input type="checkbox" id="agreeNDA" onchange="checkForm()" class="w-[18px] h-[18px] mt-0.5 accent-red shrink-0" />
          <span class="text-[13px] text-gray-800 leading-relaxed">I have read and agree to the Non-Disclosure Agreement, Non-Circumvention clause, and 2% Buyer Representative Commission terms above.</span>
        </label>
        <label class="flex items-start gap-2.5 mb-3.5 cursor-pointer">
          <input type="checkbox" id="agreeElectronic" onchange="checkForm()" class="w-[18px] h-[18px] mt-0.5 accent-red shrink-0" />
          <span class="text-[13px] text-gray-800 leading-relaxed">I consent to electronic execution of this agreement and understand this constitutes a binding legal commitment.</span>
        </label>

        <!-- Signature -->
        <div class="mt-5 pt-4 border-t border-gray-100">
          <label class="block text-[13px] text-gray-600 mb-2">Type your full legal name as your electronic signature *</label>
          <input type="text" id="signature" placeholder="John Smith" oninput="checkForm()" class="w-full px-4 py-3.5 bg-white border border-black/8 rounded-md text-[22px] font-heading italic focus:outline-none focus:border-gray-300 transition-colors" />
        </div>
      </div>
      <div class="px-8 pb-7 pt-5">
        <button class="w-full py-3.5 bg-red text-white border-none rounded-md text-sm font-semibold cursor-pointer hover:bg-red-dark transition-colors disabled:opacity-35 disabled:cursor-not-allowed font-body" id="submitBtn" disabled onclick="submitNDA()">Unlock Property Details &rarr;</button>
        <p class="text-center text-[12px] text-gray-500 mt-3">A copy of your signed agreement and the full property package will be emailed to you immediately.</p>
      </div>
    </div>
  </div>

  <!-- SUCCESS SCREEN -->
  <div class="fixed inset-0 bg-black/50 z-[1001] items-center justify-center hidden" id="successOverlay" style="display: none;">
    <div class="bg-white rounded-xl p-12 text-center max-w-[440px] shadow-2xl">
      <div class="w-14 h-14 bg-red-light rounded-full flex items-center justify-center mx-auto mb-5 text-red text-2xl">&#10003;</div>
      <h2 class="font-heading text-[28px] font-semibold text-black mb-3">Access Granted</h2>
      <p class="text-gray-600 text-[15px] mb-7 leading-relaxed">Your signed confidentiality agreement and the full property package have been sent to <strong id="successEmail">your email</strong>. Check your inbox.</p>
      <button class="inline-block px-7 py-3 bg-black text-white rounded-md font-semibold text-[13px] cursor-pointer border-none hover:bg-gray-800 transition-colors font-body" onclick="closeSuccess()">Back to Listings</button>
    </div>
  </div>

  <!-- PAGE SCRIPTS -->
  <script is:inline>
    let selectedProperty = null;
    let selectedTitle = '';

    function openNDA(propertyId, title) {
      selectedProperty = propertyId;
      selectedTitle = title;
      document.getElementById('modalPropertyName').innerHTML = title;
      const modal = document.getElementById('ndaModal');
      modal.style.display = 'flex';
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeNDA() {
      const modal = document.getElementById('ndaModal');
      modal.style.display = 'none';
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function checkForm() {
      const name = document.getElementById('fullName').value.trim();
      const email = document.getElementById('ndaEmail').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const buyerType = document.getElementById('buyerType').value;
      const agreeNDA = document.getElementById('agreeNDA').checked;
      const agreeElectronic = document.getElementById('agreeElectronic').checked;
      const signature = document.getElementById('signature').value.trim();
      const valid = name && email && phone && buyerType && agreeNDA && agreeElectronic && signature;
      document.getElementById('submitBtn').disabled = !valid;
    }

    function submitNDA() {
      const email = document.getElementById('ndaEmail').value.trim();
      document.getElementById('successEmail').textContent = email;
      closeNDA();
      const overlay = document.getElementById('successOverlay');
      overlay.style.display = 'flex';
      overlay.classList.remove('hidden');

      const leadData = {
        property: selectedProperty,
        propertyTitle: selectedTitle,
        name: document.getElementById('fullName').value,
        email: email,
        phone: document.getElementById('phone').value,
        company: document.getElementById('company').value,
        buyerType: document.getElementById('buyerType').value,
        signature: document.getElementById('signature').value,
        timestamp: new Date().toISOString()
      };

      // TODO: POST to /api/off-market-lead (ClickUp + email notification)
      console.log('LEAD CAPTURED:', leadData);
    }

    function submitDealAlert() {
      const emailInput = document.getElementById('alertEmail');
      const email = emailInput.value.trim();
      if (!email) return;
      // TODO: POST to /api/deal-alert-signup
      console.log('DEAL ALERT SIGNUP:', { email, timestamp: new Date().toISOString() });
      emailInput.value = '';
      alert('You\'re on the list. We\'ll send matching deals to ' + email);
    }

    function closeSuccess() {
      const overlay = document.getElementById('successOverlay');
      overlay.style.display = 'none';
      overlay.classList.add('hidden');
      document.querySelectorAll('#ndaModal input, #ndaModal select').forEach(el => {
        if (el.type === 'checkbox') el.checked = false;
        else el.value = '';
      });
      document.getElementById('submitBtn').disabled = true;
    }
  </script>

</BaseLayout>
