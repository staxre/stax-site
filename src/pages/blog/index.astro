---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog — Gas Station & Net Lease Insights | STAX Real Estate" description="Thought leadership, market updates, and deal insights from STAX Real Estate. Expert analysis on gas station investing, net lease capital markets, and commercial real estate strategy.">

  <!-- HERO -->
  <section class="pt-[140px] pb-[80px] px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Blog</div>
      <h1 class="font-heading text-4xl lg:text-[52px] leading-[1.12] font-semibold text-black mb-6 tracking-tight max-w-[900px]">
        Insights from the Field
      </h1>
      <p class="text-lg leading-relaxed text-gray-700 mb-9 max-w-[600px]">
        Market analysis, deal strategy, and thought leadership from someone who's owned and operated the business — not just brokered it.
      </p>
    </div>
  </section>

  <!-- FEATURED POST -->
  {posts.length > 0 && (
    <section class="px-6 lg:px-12 pb-16">
      <div class="max-w-[1200px] mx-auto">
        <a href={`/blog/${posts[0].slug}`} class="block group">
          <div class="flex flex-col lg:flex-row rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all">
            <div class="w-full lg:w-[500px] h-[300px] lg:h-auto shrink-0 bg-gray-100 overflow-hidden">
              {posts[0].data.image ? (
                <img src={posts[0].data.image} alt={posts[0].data.title} class="w-full h-full object-cover" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-red/10 to-red/5 flex items-center justify-center">
                  <span class="text-red font-heading text-2xl font-semibold opacity-40">STAX</span>
                </div>
              )}
            </div>
            <div class="p-10 flex-1">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-block text-[10px] font-semibold text-white bg-red px-2.5 py-1 rounded">{posts[0].data.category}</span>
                <span class="text-[13px] text-gray-500">{formatDate(posts[0].data.date)}</span>
              </div>
              <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-black mb-4 group-hover:text-red transition-colors">
                {posts[0].data.title}
              </h2>
              <p class="text-[15px] leading-relaxed text-gray-700 mb-6">
                {posts[0].data.excerpt}
              </p>
              <span class="text-sm font-semibold text-red">Read article &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ALL POSTS GRID -->
  <section class="px-6 lg:px-12 pb-24">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="font-heading text-2xl font-semibold text-black mb-10">All Articles</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.slice(1).map((post) => (
          <a href={`/blog/${post.slug}`} class="group block rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all">
            <div class="h-[180px] bg-gray-100 overflow-hidden">
              {post.data.image ? (
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-50 flex items-center justify-center">
                  <span class="text-gray-300 font-heading text-xl font-semibold">STAX</span>
                </div>
              )}
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block text-[10px] font-semibold text-white bg-red px-2 py-0.5 rounded">{post.data.category}</span>
                <span class="text-[12px] text-gray-500">{formatDate(post.data.date)}</span>
              </div>
              <h3 class="font-heading text-lg font-semibold text-black mb-2 group-hover:text-red transition-colors leading-snug">
                {post.data.title}
              </h3>
              <p class="text-[14px] leading-relaxed text-gray-600 line-clamp-3">
                {post.data.excerpt}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 lg:px-12 bg-black text-white">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold mb-6">Have a Deal to Discuss?</h2>
      <p class="text-lg text-gray-400 mb-10">Whether you're buying, selling, or just exploring the gas station and net lease market — we're here to help.</p>
      <a href="/contact" class="inline-block bg-red text-white font-semibold px-8 py-3.5 rounded-lg hover:bg-red/90 transition-colors">
        Start a Conversation
      </a>
    </div>
  </section>

</BaseLayout>
