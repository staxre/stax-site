---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="STAX Real Estate — Gas Station & Net Lease Brokerage">

  <!-- HERO -->
  <section class="pt-[140px] pb-[80px] px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <span class="inline-block text-[11px] font-semibold tracking-[2px] uppercase text-red bg-red-light px-3.5 py-1.5 rounded mb-5">
          Gas Station & C-Store Brokerage
        </span>
        <h1 class="font-heading text-4xl lg:text-[52px] leading-[1.12] font-semibold text-black mb-6 tracking-tight">
          We've Run the Business. That's Why We're Better at the Deal.
        </h1>
        <p class="text-lg leading-relaxed text-gray-700 mb-9 max-w-[500px]">
          STAX is the only brokerage built by someone who's owned and operated a dozen gas stations. Whether you're selling your station or buying one as an investment, you're working with someone who knows every detail of the business.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <a href="/contact" class="inline-flex items-center gap-2.5 bg-red text-white px-8 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors tracking-wide">
            Schedule a Call
            <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/valuation" class="text-sm font-medium text-gray-700 hover:text-black transition-colors">
            What's my station worth? →
          </a>
        </div>
      </div>
      <div class="relative h-[400px] lg:h-[480px] rounded-xl overflow-hidden bg-gray-100">
        <img src="/images/hero-shell-station.jpg" alt="Shell Gas Station - STAX Real Estate" class="w-full h-full object-cover" />
        <div class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-sm px-8 py-6 flex gap-10 border-t border-black/5">
          <div>
            <div class="font-heading text-[28px] font-bold text-black">180+</div>
            <div class="text-[11px] text-gray-500 uppercase tracking-wider mt-0.5">Stations Sold</div>
          </div>
          <div>
            <div class="font-heading text-[28px] font-bold text-black">$525M+</div>
            <div class="text-[11px] text-gray-500 uppercase tracking-wider mt-0.5">Transaction Volume</div>
          </div>
          <div>
            <div class="font-heading text-[28px] font-bold text-black">$2B+</div>
            <div class="text-[11px] text-gray-500 uppercase tracking-wider mt-0.5">Aggregate Lease Value</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AS FEATURED IN -->
  <section class="py-14 px-6 lg:px-12 border-y border-gray-100">
    <div class="max-w-[1200px] mx-auto text-center">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-gray-500 mb-7">As Featured In</div>
      <div class="flex items-center justify-center gap-8 lg:gap-10 flex-wrap opacity-50 grayscale">
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">NAIOP</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">The Verge</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">The Real Deal</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">Bisnow</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">Yahoo Finance</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">C-Store Dive</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">CCR Magazine</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">SFBW</span>
        </a>
        <a href="/press" class="hover:opacity-80 transition-opacity">
          <span class="text-[15px] font-bold text-gray-900 tracking-wide">MarketWatch</span>
        </a>
      </div>
      <a href="/press" class="inline-block mt-5 text-[12px] font-semibold text-red hover:text-red-dark transition-colors tracking-wide uppercase">See all press coverage →</a>
    </div>
  </section>

  <!-- WHY STAX — THE OPERATOR DIFFERENCE -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">The Operator Difference</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">
        Most brokers read the spreadsheet. We've lived the P&L.
      </h2>
      <p class="text-[17px] leading-relaxed text-gray-700 max-w-[640px] mb-12">
        STAX founder Michael Salafia served as CEO of a multi-location gas station operating company — a dozen stations with c-stores. That means we evaluate your deal the way an owner would — gallonage, margin, brand contracts, environmental exposure — not just the cap rate.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="border border-black/8 rounded-xl p-8 bg-white">
          <div class="text-red font-heading text-3xl font-bold mb-2">01</div>
          <h3 class="font-heading text-lg font-semibold text-black mb-2">Operator's Eye</h3>
          <p class="text-sm leading-relaxed text-gray-700">We catch what spreadsheet brokers miss. We've run the business across a dozen locations — so we evaluate deals the way an operator would.</p>
        </div>
        <div class="border border-black/8 rounded-xl p-8 bg-white">
          <div class="text-red font-heading text-3xl font-bold mb-2">02</div>
          <h3 class="font-heading text-lg font-semibold text-black mb-2">Principal Access</h3>
          <p class="text-sm leading-relaxed text-gray-700">No associates, no handoffs. You work directly with the person who closes your deal, from first call to final signature.</p>
        </div>
        <div class="border border-black/8 rounded-xl p-8 bg-white">
          <div class="text-red font-heading text-3xl font-bold mb-2">03</div>
          <h3 class="font-heading text-lg font-semibold text-black mb-2">Tax Strategy Built In</h3>
          <p class="text-sm leading-relaxed text-gray-700">We structure deals around bonus depreciation, cost segregation, and 1031 exchanges. The tax play isn't an afterthought — it's part of the deal from day one.</p>
        </div>
        <div class="border border-black/8 rounded-xl p-8 bg-white">
          <div class="text-red font-heading text-3xl font-bold mb-2">04</div>
          <h3 class="font-heading text-lg font-semibold text-black mb-2">Both Sides of the Counter</h3>
          <p class="text-sm leading-relaxed text-gray-700">We sell stations to operators AND structure NNN deals for passive investors. That dual network means better matches and faster closes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO WE WORK WITH -->
  <section class="py-24 px-6 lg:px-12 bg-gray-100">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Who We Work With</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">
        Three types of clients. One broker who gets all three.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
        <!-- Sellers -->
        <a href="/sellers" class="group border border-black/8 rounded-xl p-10 hover:border-red hover:shadow-lg hover:-translate-y-0.5 transition-all bg-white">
          <div class="w-12 h-12 rounded-lg bg-red-light flex items-center justify-center mb-5 text-red">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-heading text-[22px] font-semibold text-black mb-3">Selling Your Station?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-5">You built this business. We'll make sure you're not leaving money on the table. We price based on the full picture — gallonage, margin, brand, location — not just the cap rate.</p>
          <span class="text-[13px] font-semibold text-red tracking-wide inline-flex items-center gap-1.5 group-hover:gap-3 transition-all">Get a valuation →</span>
        </a>
        <!-- NNN Investors -->
        <a href="/buyers" class="group border border-black/8 rounded-xl p-10 hover:border-red hover:shadow-lg hover:-translate-y-0.5 transition-all bg-white">
          <div class="w-12 h-12 rounded-lg bg-red-light flex items-center justify-center mb-5 text-red">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
          </div>
          <h3 class="font-heading text-[22px] font-semibold text-black mb-3">Looking for Tax-Advantaged NNN?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-5">Gas stations are the last great tax shelter. 100% bonus depreciation, Year 1 write-off, in income-tax-free states. We source deals from operators who trust us because we've been in their shoes.</p>
          <span class="text-[13px] font-semibold text-red tracking-wide inline-flex items-center gap-1.5 group-hover:gap-3 transition-all">See current deals →</span>
        </a>
        <!-- Operators -->
        <a href="/operators" class="group border border-black/8 rounded-xl p-10 hover:border-red hover:shadow-lg hover:-translate-y-0.5 transition-all bg-white">
          <div class="w-12 h-12 rounded-lg bg-red-light flex items-center justify-center mb-5 text-red">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-heading text-[22px] font-semibold text-black mb-3">Growing Your Portfolio?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700 mb-5">Whether you're going from 1 station to 5 or repositioning to exit, we help operators buy, sell, and scale. We've done the math on hundreds of station P&Ls — we know what a good deal looks like.</p>
          <span class="text-[13px] font-semibold text-red tracking-wide inline-flex items-center gap-1.5 group-hover:gap-3 transition-all">Let's talk growth →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- WHY GAS STATIONS -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">The Asset Class</div>
          <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">
            Why gas stations are the smartest NNN play right now
          </h2>
          <p class="text-[17px] leading-relaxed text-gray-700 mb-8">
            Gas stations and c-stores combine recession-resistant income with the most aggressive tax benefits in commercial real estate. Here's why investors are paying attention.
          </p>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-red-light flex items-center justify-center shrink-0 mt-0.5">
                <div class="w-2 h-2 rounded-full bg-red"></div>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">100% Bonus Depreciation</h4>
                <p class="text-sm text-gray-700 leading-relaxed">Cost segregation on gas station improvements means investors can write off nearly the entire purchase price in Year 1. No other NNN asset class offers this.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-red-light flex items-center justify-center shrink-0 mt-0.5">
                <div class="w-2 h-2 rounded-full bg-red"></div>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">Recession-Resistant Demand</h4>
                <p class="text-sm text-gray-700 leading-relaxed">People still need gas when the economy contracts. Gas stations and c-stores are essential infrastructure — not discretionary retail.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-red-light flex items-center justify-center shrink-0 mt-0.5">
                <div class="w-2 h-2 rounded-full bg-red"></div>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">Long-Term NNN Leases</h4>
                <p class="text-sm text-gray-700 leading-relaxed">National brands like Shell, Chevron, and Circle K typically sign 10-25 year leases with built-in escalations. Predictable, bond-like income.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 rounded-full bg-red-light flex items-center justify-center shrink-0 mt-0.5">
                <div class="w-2 h-2 rounded-full bg-red"></div>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">Income-Tax-Free States</h4>
                <p class="text-sm text-gray-700 leading-relaxed">We focus on Florida, Texas, Nevada, and Tennessee — states with no income tax, which means the depreciation benefits go even further.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="h-[500px] rounded-xl bg-gray-100 flex items-center justify-center text-sm text-gray-500 overflow-hidden">
          <img src="/images/refilling-station.jpg" alt="Gas Station Refueling Station" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED DEALS -->
  <section class="py-24 px-6 lg:px-12 bg-gray-100">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Current Listings</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">Active deals</h2>
      <p class="text-[17px] leading-relaxed text-gray-700 max-w-[600px] mb-12">A preview of what's available. Get full details — financials, lease terms, and due diligence packages — when you request a full package.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/deals" class="rounded-xl overflow-hidden bg-white border border-black/8 hover:shadow-xl hover:-translate-y-0.5 transition-all group">
          <div class="h-[200px] bg-gray-200 relative flex items-center justify-center text-sm text-gray-500 overflow-hidden">
            <img src="/images/listing-wellington-shell.jpg" alt="Shell Gas Station Wellington FL" class="w-full h-full object-cover" />
            <span class="absolute top-3 left-3 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Shell</span>
            <span class="absolute top-3 right-3 bg-black text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">$12.5M</span>
          </div>
          <div class="p-6">
            <h4 class="font-heading text-lg font-semibold mb-1">Shell — Wellington, FL</h4>
            <div class="text-[13px] text-gray-500 mb-4">Flagship &middot; 8.80% Cap &middot; $1.1M NOI</div>
            <div class="flex gap-6 pt-4 border-t border-gray-100">
              <div><span class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Inside Sales</span><strong class="text-[15px] text-black">$325K/mo</strong></div>
            </div>
          </div>
        </a>
        <a href="/deals" class="rounded-xl overflow-hidden bg-white border border-black/8 hover:shadow-xl hover:-translate-y-0.5 transition-all group">
          <div class="h-[200px] bg-gray-200 relative flex items-center justify-center text-sm text-gray-500 overflow-hidden">
            <img src="/images/listing-stpete-portfolio.jpg" alt="Gas Station Portfolio St. Petersburg FL" class="w-full h-full object-cover" />
            <span class="absolute top-3 left-3 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Portfolio</span>
            <span class="absolute top-3 right-3 bg-black text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">$6M</span>
          </div>
          <div class="p-6">
            <h4 class="font-heading text-lg font-semibold mb-1">3-Site Portfolio — St. Pete, FL</h4>
            <div class="text-[13px] text-gray-500 mb-4">Open Fuel Contracts &middot; $2M/site</div>
            <div class="flex gap-6 pt-4 border-t border-gray-100">
              <div><span class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Gallons</span><strong class="text-[15px] text-black">210K/mo</strong></div>
            </div>
          </div>
        </a>
        <a href="/deals" class="rounded-xl overflow-hidden bg-white border border-black/8 hover:shadow-xl hover:-translate-y-0.5 transition-all group">
          <div class="h-[200px] bg-gray-200 relative flex items-center justify-center text-sm text-gray-500 overflow-hidden">
            <img src="/images/listing-tampa-texaco.jpg" alt="Texaco Gas Station Tampa FL" class="w-full h-full object-cover" />
            <span class="absolute top-3 left-3 bg-red text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Texaco</span>
            <span class="absolute top-3 right-3 bg-black text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">$2.8M</span>
          </div>
          <div class="p-6">
            <h4 class="font-heading text-lg font-semibold mb-1">Texaco — Tampa, FL</h4>
            <div class="text-[13px] text-gray-500 mb-4">Value-Add &middot; Near USF &middot; U-Haul</div>
            <div class="flex gap-6 pt-4 border-t border-gray-100">
              <div><span class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Margins</span><strong class="text-[15px] text-red">40%</strong></div>
            </div>
          </div>
        </a>
        <a href="/deals" class="rounded-xl overflow-hidden bg-white border border-amber-300 hover:shadow-xl hover:-translate-y-0.5 transition-all group relative">
          <div class="h-[200px] bg-gray-200 relative flex items-center justify-center text-sm text-gray-500 overflow-hidden">
            <img src="/images/listing-lakeland-chevron.jpg" alt="Chevron Gas Station Lakeland FL" class="w-full h-full object-cover" />
            <span class="absolute top-3 left-3 bg-amber-500 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">Under Contract</span>
            <span class="absolute top-3 right-3 bg-black text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">$1.99M</span>
          </div>
          <div class="p-6">
            <h4 class="font-heading text-lg font-semibold mb-1">Chevron — Lakeland, FL</h4>
            <div class="text-[13px] text-gray-500 mb-4">Under Contract &middot; Krispy Krunchy QSR</div>
            <div class="flex gap-6 pt-4 border-t border-gray-100">
              <div><span class="block text-[10px] font-semibold text-gray-500 uppercase tracking-wider">Volume</span><strong class="text-[15px] text-black">55K/mo</strong></div>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center mt-10">
        <a href="/deals" class="inline-flex items-center gap-2 bg-black text-white px-7 py-3.5 rounded-md text-sm font-semibold hover:bg-gray-900 transition-colors">View All Listings →</a>
      </div>
    </div>
  </section>

  <!-- RECENT CLOSINGS -->
  <section class="py-24 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Track Record</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-5 tracking-tight leading-snug">Stations we've closed</h2>
      <p class="text-[17px] leading-relaxed text-gray-700 max-w-[600px] mb-12">Every deal below involved hands-on evaluation of operations, environmental, and lease terms — not just a cap rate on a spreadsheet.</p>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
