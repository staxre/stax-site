---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact & Schedule a Call — STAX Real Estate" description="Call STAX Real Estate directly — speak with our front desk immediately or book a meeting with founder Michael Salafia. No associates, no handoffs. Principal-to-principal.">

  <!-- HERO -->
  <section class="pt-[140px] pb-16 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Get in Touch</div>
      <h1 class="font-heading text-4xl lg:text-[52px] leading-[1.12] font-semibold text-black mb-6 tracking-tight max-w-[900px]">
        Let's Talk About Your Station.
      </h1>
      <p class="text-lg leading-relaxed text-gray-700 mb-10 max-w-[600px]">
        Whether you're selling a gas station, buying your next one, or exploring a NNN investment — let's have a conversation. No pitch. No pressure. Just a principal-to-principal discussion about your situation.
      </p>

      <!-- PRIMARY CTA: Call Now -->
      <a href="tel:+13217700222" class="inline-flex items-center gap-3 bg-red text-white px-10 py-5 rounded-xl text-[18px] font-bold hover:bg-red-dark transition-colors shadow-lg shadow-red/20 active:scale-[0.98] transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
        </svg>
        Call Now — (321) 770-0222
      </a>
      <p class="text-[14px] text-gray-500 mt-4 max-w-[440px]">
        Our front desk picks up immediately. Tell us what you're looking for and we'll get the right person on the phone.
      </p>
    </div>
  </section>

  <!-- TWO PATHS: CALL vs BOOK -->
  <section class="py-20 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- LEFT: Contact Info + Call -->
      <div class="lg:col-span-2 space-y-10">

        <!-- How Calling Works -->
        <div class="bg-white rounded-xl border border-black/8 p-10">
          <h2 class="font-heading text-2xl font-semibold text-black mb-6">What Happens When You Call</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center shrink-0">
                <span class="text-red font-heading font-bold">1</span>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">Kate picks up</h4>
                <p class="text-[15px] text-gray-700 leading-relaxed">Our front desk answers right away. Tell her what you're calling about — selling, buying, investing, or just exploring.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center shrink-0">
                <span class="text-red font-heading font-bold">2</span>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">She takes your details</h4>
                <p class="text-[15px] text-gray-700 leading-relaxed">Name, property info, and what you're looking to accomplish. She'll also schedule a callback time that works for you.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-red/10 flex items-center justify-center shrink-0">
                <span class="text-red font-heading font-bold">3</span>
              </div>
              <div>
                <h4 class="font-semibold text-black mb-1">Michael calls you back</h4>
                <p class="text-[15px] text-gray-700 leading-relaxed">Usually within 15 minutes. You'll speak directly with the founder — no associates, no handoffs. The person who takes your call is the person who closes your deal.</p>
              </div>
            </div>
          </div>

          <!-- Mobile-friendly call button repeated -->
          <div class="mt-8 lg:hidden">
            <a href="tel:+13217700222" class="flex items-center justify-center gap-3 bg-red text-white w-full py-4 rounded-xl text-[16px] font-bold active:scale-[0.98] transition-transform">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
              </svg>
              Tap to Call Now
            </a>
          </div>
        </div>

        <!-- Self-Schedule Option -->
        <div class="bg-gray-50 rounded-xl border border-black/8 p-10">
          <h2 class="font-heading text-2xl font-semibold text-black mb-3">Prefer to Book Online?</h2>
          <p class="text-[15px] text-gray-700 leading-relaxed mb-6">
            Skip the phone and book directly on Michael's calendar. Pick any open slot and you'll get a confirmation instantly — no back-and-forth.
          </p>
          <a href="https://calendly.com/michael-staxre" target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 bg-black text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-gray-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
            </svg>
            Book a Meeting Instantly
          </a>
          <p class="text-[13px] text-gray-500 mt-4">
            20-30 minute call. Self-service scheduling — pick a time and it's confirmed.
          </p>
        </div>

        <!-- Contact Form -->
        <div>
          <h3 class="font-heading text-xl font-semibold text-black mb-6">Or Send a Message</h3>
          <form action="https://formspree.io/f/michael@staxre.com" method="POST" class="bg-white rounded-xl border border-black/8 p-10 space-y-6">
            <input type="hidden" name="_subject" value="New Contact from STAX Website" />
            <input type="hidden" name="_next" value="/contact?thanks=1" />
            <input type="text" name="_gotcha" style="display:none" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-[13px] font-semibold text-gray-900 uppercase tracking-wider mb-2">
                  Your Name *
                </label>
                <input type="text" name="name" placeholder="John Smith" class="w-full px-5 py-3.5 rounded-lg border border-gray-300 text-[15px] focus:outline-none focus:border-red transition-colors" required />
              </div>
              <div>
                <label class="block text-[13px] font-semibold text-gray-900 uppercase tracking-wider mb-2">
                  Phone Number *
                </label>
                <input type="tel" name="phone" placeholder="(305) 555-0000" class="w-full px-5 py-3.5 rounded-lg border border-gray-300 text-[15px] focus:outline-none focus:border-red transition-colors" required />
              </div>
            </div>

            <div>
              <label class="block text-[13px] font-semibold text-gray-900 uppercase tracking-wider mb-2">
                Email Address *
              </label>
              <input type="email" name="email" placeholder="your@email.com" class="w-full px-5 py-3.5 rounded-lg border border-gray-300 text-[15px] focus:outline-none focus:border-red transition-colors" required />
            </div>

            <div>
              <label class="block text-[13px] font-semibold text-gray-900 uppercase tracking-wider mb-2">
                I'm Interested In *
              </label>
              <select name="interest" class="w-full px-5 py-3.5 rounded-lg border border-gray-300 text-[15px] focus:outline-none focus:border-red transition-colors appearance-none bg-white cursor-pointer" required>
                <option value="">Select one...</option>
                <option value="selling">Selling my gas station / c-store</option>
                <option value="buying-operator">Buying a gas station (operator)</option>
                <option value="buying-investor">NNN investment / bonus depreciation</option>
                <option value="valuation">Getting a property valuation</option>
                <option value="1031">1031 exchange guidance</option>
                <option value="portfolio">Portfolio strategy</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label class="block text-[13px] font-semibold text-gray-900 uppercase tracking-wider mb-2">
                Message *
              </label>
              <textarea name="message" placeholder="Tell us about your situation — what kind of station, where it's located, your timeline, and what you're looking to accomplish." rows="6" class="w-full px-5 py-3.5 rounded-lg border border-gray-300 text-[15px] focus:outline-none focus:border-red transition-colors resize-none" required></textarea>
            </div>

            <button type="submit" class="w-full bg-red text-white px-8 py-4 rounded-lg text-[15px] font-semibold hover:bg-red-dark transition-colors">
              Send Message
            </button>

            <p class="text-[12px] text-gray-600 text-center">
              We respond within 24 hours. Usually by phone so we can have a real conversation.
            </p>
          </form>
        </div>
      </div>

      <!-- RIGHT: Contact Info Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-gray-100 rounded-xl p-10 sticky top-24">
          <h3 class="font-heading text-xl font-semibold text-black mb-8">Direct to Michael</h3>

          <div class="space-y-8">
            <!-- Phone -->
            <div>
              <p class="text-[11px] font-semibold text-gray-600 uppercase tracking-wider mb-2">Phone</p>
              <a href="tel:+13217700222" class="text-[18px] font-semibold text-black hover:text-red transition-colors">
                (321) 770-0222
              </a>
              <p class="text-[12px] text-gray-600 mt-2">Call anytime — our front desk picks up immediately.</p>
            </div>

            <!-- Email -->
            <div>
              <p class="text-[11px] font-semibold text-gray-600 uppercase tracking-wider mb-2">Email</p>
              <a href="mailto:michael@staxre.com" class="text-[18px] font-semibold text-black hover:text-red transition-colors break-all">
                michael@staxre.com
              </a>
              <p class="text-[12px] text-gray-600 mt-2">Direct to Michael. Response within 24 hours.</p>
            </div>

            <!-- Address -->
            <div>
              <p class="text-[11px] font-semibold text-gray-600 uppercase tracking-wider mb-2">Office</p>
              <address class="text-[15px] text-black not-italic leading-relaxed">
                STAX Real Estate LLC<br />
                1111 Lincoln Rd<br />
                Suite 500<br />
                Miami Beach, FL 33139
              </address>
            </div>

            <!-- Hours -->
            <div class="pt-4 border-t border-gray-200">
              <p class="text-[11px] font-semibold text-gray-600 uppercase tracking-wider mb-3">Availability</p>
              <div class="space-y-1 text-[14px] text-gray-700">
                <div>Monday – Friday: 9am – 6pm ET</div>
                <div>Saturday – Sunday: By appointment</div>
              </div>
            </div>
          </div>

          <!-- Additional Links -->
          <div class="mt-10 pt-8 border-t border-gray-200">
            <p class="text-[13px] text-gray-700 font-semibold mb-4">Not ready to talk yet?</p>
            <div class="space-y-2">
              <a href="/valuation" class="block text-[14px] font-semibold text-red hover:text-red-dark transition-colors">
                → Get a Free Station Valuation
              </a>
              <a href="/case-studies" class="block text-[14px] font-semibold text-red hover:text-red-dark transition-colors">
                → See Our Deal Stories
              </a>
              <a href="/deals" class="block text-[14px] font-semibold text-red hover:text-red-dark transition-colors">
                → Browse Current Deals
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-6 lg:px-12 bg-gray-100">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-[11px] font-semibold tracking-[2px] uppercase text-red mb-4">Common Questions</div>
      <h2 class="font-heading text-3xl lg:text-[40px] font-semibold text-black mb-12 tracking-tight leading-snug">What to Expect</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-8 border border-black/8">
          <h3 class="font-heading text-lg font-semibold text-black mb-3">Who will I be talking to?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">
            Michael Salafia — founder, principal broker, and former CEO of a dozen-location gas station operating company. No associates, no junior agents. The person who takes your call is the person who closes your deal.
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-black/8">
          <h3 class="font-heading text-lg font-semibold text-black mb-3">Do I need to be ready to sell or buy?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">
            No. Some clients are actively listing, some are exploring options, some are 12-18 months out. We work with all stages. Let's just talk about what you're thinking.
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-black/8">
          <h3 class="font-heading text-lg font-semibold text-black mb-3">What if my station is outside Florida?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">
            We work nationally, with primary focus on income-tax-free states (FL, TX, NV, TN). If your station is elsewhere, we'll evaluate whether we can add value or refer you to someone who can.
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-black/8">
          <h3 class="font-heading text-lg font-semibold text-black mb-3">What's your commission structure?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">
            Standard brokerage commissions on completed transactions. We'll discuss fees transparently before you commit to anything. No surprises.
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-black/8">
          <h3 class="font-heading text-lg font-semibold text-black mb-3">What makes STAX different from other brokers?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">
            We've owned and operated a dozen gas stations. That firsthand experience changes how we value properties, spot risk, and close deals. Plus we sell to both operators and NNN investors — which means more demand and better pricing.
          </p>
        </div>

        <div class="bg-white rounded-xl p-8 border border-black/8">
          <h3 class="font-heading text-lg font-semibold text-black mb-3">Can I get references?</h3>
          <p class="text-[15px] leading-relaxed text-gray-700">
            Absolutely. We'll connect you with operators and investors from recent closings. 180+ gas stations sold — there's no shortage of people to talk to.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-gradient-to-br from-black to-[#1a1a2e] py-20 px-6 lg:px-12 text-center">
    <div class="max-w-[640px] mx-auto">
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-white mb-4">Ready to Talk?</h2>
      <p class="text-[17px] leading-relaxed text-white/60 mb-8">Our front desk picks up immediately. Tell us what you're looking for and Michael will call you back — usually within 15 minutes.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="tel:+13217700222" class="inline-flex items-center gap-2.5 bg-red text-white px-9 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          Call (321) 770-0222
        </a>
        <a href="https://calendly.com/michael-staxre" target="_blank" rel="noopener" class="text-[14px] font-semibold text-white/70 hover:text-white transition-colors">
          or book online →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
