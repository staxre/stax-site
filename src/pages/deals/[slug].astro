---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import {
  getPublishedListings,
  getOnMarketListings,
  generateListingTitle,
  generateListingDescription,
  formatPrice,
  formatNumber,
} from '../../lib/listings';
import type { Listing } from '../../lib/listings';

export async function getStaticPaths() {
  const data = await getPublishedListings();
  const onMarket = getOnMarketListings(data);

  return onMarket.map((listing) => ({
    params: { slug: listing.slug },
    props: { listing, allListings: onMarket },
  }));
}

interface Props {
  listing: Listing;
  allListings: Listing[];
}

const { listing, allListings } = Astro.props;

const title = generateListingTitle(listing);
const description = generateListingDescription(listing);
const ogImage = listing.hero_image_url || '/images/hero-shell-station.jpg';

// Related listings: other on-market listings (exclude current), max 3
const related = allListings
  .filter((l) => l.slug !== listing.slug)
  .slice(0, 3);

// Build metrics array for the detail grid
const detailMetrics: Array<{ label: string; value: string }> = [];
if (listing.asking_price) detailMetrics.push({ label: "Asking Price", value: formatPrice(listing.asking_price) });
if (listing.cap_rate) detailMetrics.push({ label: "Cap Rate", value: `${listing.cap_rate}%` });
if (listing.noi) detailMetrics.push({ label: "NOI", value: formatPrice(listing.noi) });
if (listing.ebitda) detailMetrics.push({ label: "EBITDA", value: formatPrice(listing.ebitda) });
if (listing.monthly_gallons) detailMetrics.push({ label: "Fuel Volume", value: `${formatNumber(listing.monthly_gallons)}/mo` });
if (listing.vpd) detailMetrics.push({ label: "AADT", value: formatNumber(listing.vpd) });

// Use flexible metrics from DB if available
const displayMetrics = listing.metrics && Object.keys(listing.metrics).length > 0
  ? Object.entries(listing.metrics).map(([label, value]) => ({ label, value }))
  : detailMetrics;

const highlights = listing.highlights ?? [];
const badges = listing.display_badges ?? [];
const gallery = listing.gallery_image_urls ?? [];
const isUnderContract = listing.status === 'under_contract';

// Property details for sidebar
const propertyDetails: Array<{ label: string; value: string }> = [
  listing.address && { label: "Address", value: listing.address },
  listing.city && { label: "City", value: `${listing.city}, ${listing.state || 'FL'}` },
  listing.county && { label: "County", value: listing.county },
  listing.brand && { label: "Brand", value: listing.brand },
  listing.property_type && { label: "Type", value: listing.property_type },
  listing.building_sqft && { label: "Building", value: `${listing.building_sqft.toLocaleString()} SF` },
  listing.lot_acres && { label: "Lot Size", value: `${listing.lot_acres} AC` },
  listing.deal_type && { label: "Sale Type", value: listing.deal_type },
].filter(Boolean) as Array<{ label: string; value: string }>;

// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateListing",
  "name": listing.name,
  "description": listing.website_description || description,
  "url": `https://staxre.com/deals/${listing.slug}`,
  ...(listing.hero_image_url && { "image": listing.hero_image_url }),
  ...(listing.published_at && { "datePosted": listing.published_at }),
  "address": {
    "@type": "PostalAddress",
    ...(listing.address && { "streetAddress": listing.address }),
    "addressLocality": listing.city,
    "addressRegion": listing.state || "FL",
    "addressCountry": "US",
  },
  ...(listing.asking_price && {
    "offers": {
      "@type": "Offer",
      "price": listing.asking_price,
      "priceCurrency": "USD",
    },
  }),
  "broker": {
    "@type": "RealEstateAgent",
    "name": "STAX Real Estate",
    "url": "https://staxre.com",
    "telephone": "+1-321-770-0222",
  },
};
---

<BaseLayout title={title} description={description} ogImage={ogImage}>

  {/* Listing-specific JSON-LD */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumbs */}
  <section class="pt-[100px] pb-0 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">
      <nav class="text-[13px] text-gray-500">
        <a href="/deals" class="hover:text-red transition-colors">Deals</a>
        <span class="mx-2">/</span>
        <span class="text-black font-medium">{listing.name}</span>
      </nav>
    </div>
  </section>

  {/* Hero */}
  <section class="pt-8 pb-12 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto">

      {/* Under Contract Banner */}
      {isUnderContract && (
        <div class="bg-amber-500 text-white text-center py-3 rounded-t-xl text-[13px] font-bold tracking-widest uppercase mb-0">
          Under Contract at List Price
        </div>
      )}

      {/* Hero Image */}
      {listing.hero_image_url && (
        <div class:list={["w-full h-[400px] lg:h-[500px] overflow-hidden bg-gray-100", isUnderContract ? "rounded-b-xl" : "rounded-xl"]}>
          <img
            src={listing.hero_image_url}
            alt={`${listing.name} — ${listing.city}, ${listing.state}`}
            class="w-full h-full object-cover"
          />
        </div>
      )}

      {/* Badges */}
      {badges.length > 0 && (
        <div class="flex items-center gap-3 mt-8">
          {badges.map((badge) => (
            <span
              class="inline-block text-[10px] font-semibold px-3 py-1.5 rounded uppercase tracking-wider"
              style={`color: white; background-color: ${badge.color === "red" ? "#DA291C" : badge.color === "amber" ? "#f59e0b" : badge.color === "black" ? "#000" : badge.color}`}
            >
              {badge.text}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-heading text-3xl lg:text-[44px] leading-[1.15] font-semibold text-black mt-6 mb-4 tracking-tight">
        {listing.name}
      </h1>

      {listing.city && (
        <p class="text-lg text-gray-500 mb-8">
          {[listing.address, listing.city, listing.state].filter(Boolean).join(", ")}
        </p>
      )}
    </div>
  </section>

  {/* Main Content Grid */}
  <section class="pb-16 px-6 lg:px-12">
    <div class="max-w-[1200px] mx-auto lg:grid lg:grid-cols-[1fr_360px] lg:gap-16">

      {/* Left Column: Description + Metrics */}
      <div>
        {/* Key Metrics */}
        {displayMetrics.length > 0 && (
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 mb-12 pb-12 border-b border-gray-100">
            {displayMetrics.map((m, i) => (
              <div>
                <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-1">{m.label}</div>
                <div class:list={["font-heading text-3xl font-bold", i === 0 ? "text-red" : "text-black"]}>
                  {m.value}
                </div>
              </div>
            ))}
          </div>
        )}

        {/* Highlights */}
        {highlights.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-10">
            {highlights.map((h) => (
              <span class="text-[12px] font-medium text-gray-700 bg-gray-100 px-4 py-2 rounded-full">{h}</span>
            ))}
          </div>
        )}

        {/* Description */}
        {listing.website_description && (
          <div class="prose prose-lg max-w-none mb-12">
            <p class="text-[16px] leading-[1.8] text-gray-700 whitespace-pre-line">
              {listing.website_description}
            </p>
          </div>
        )}

        {/* Photo Gallery */}
        {gallery.length > 0 && (
          <div class="mb-12">
            <h2 class="font-heading text-2xl font-semibold text-black mb-6">Photos</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {gallery.map((url, i) => (
                <div class="rounded-lg overflow-hidden bg-gray-100 h-[240px]">
                  <img
                    src={url}
                    alt={`${listing.name} — Photo ${i + 1}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Right Column: Sidebar */}
      <div>
        {/* Property Details Card */}
        <div class="bg-gray-50 rounded-xl p-8 mb-8 sticky top-[88px]">
          <h3 class="font-heading text-lg font-semibold text-black mb-6">Property Details</h3>
          <dl class="space-y-4">
            {propertyDetails.map((d) => (
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">{d.label}</dt>
                <dd class="text-sm font-medium text-black text-right">{d.value}</dd>
              </div>
            ))}
          </dl>

          <div class="mt-8 pt-6 border-t border-gray-200">
            {!isUnderContract ? (
              <a href="/contact" class="block w-full text-center bg-red text-white py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors">
                Schedule a Call
              </a>
            ) : (
              <div class="block w-full text-center bg-amber-500 text-white py-4 rounded-md text-[15px] font-semibold">
                Under Contract
              </div>
            )}
            <p class="text-center text-[12px] text-gray-500 mt-3">
              <a href="tel:+13217700222" class="text-red hover:underline">(321) 770-0222</a>
              &middot;
              <a href="mailto:michael@staxre.com" class="text-red hover:underline">michael@staxre.com</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Related Listings */}
  {related.length > 0 && (
    <section class="py-20 px-6 lg:px-12 bg-gray-50">
      <div class="max-w-[1200px] mx-auto">
        <h2 class="font-heading text-2xl lg:text-3xl font-semibold text-black mb-10">Other Opportunities</h2>
        <div class="space-y-12">
          {related.map((r) => (
            <ListingCard listing={r} mode="on-market" />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="bg-gradient-to-br from-black to-[#1a1a2e] py-20 px-6 lg:px-12 text-center">
    <div class="max-w-[640px] mx-auto">
      <h2 class="font-heading text-3xl lg:text-4xl font-semibold text-white mb-4">Looking for something different?</h2>
      <p class="text-[17px] leading-relaxed text-white/60 mb-8">Tell us your criteria — investment size, cap rate, geography, deal type — and we'll match you with current and upcoming opportunities.</p>
      <a href="/contact" class="inline-flex items-center gap-2.5 bg-red text-white px-9 py-4 rounded-md text-[15px] font-semibold hover:bg-red-dark transition-colors">
        Schedule a Call
        <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  {/* BreadcrumbList JSON-LD */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Deals", "item": "https://staxre.com/deals" },
      { "@type": "ListItem", "position": 2, "name": listing.name, "item": `https://staxre.com/deals/${listing.slug}` },
    ],
  })} />

</BaseLayout>
