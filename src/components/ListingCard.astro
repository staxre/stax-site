---
/**
 * ListingCard — reusable listing card for /deals and /off-market index pages.
 *
 * Renders the same card layout as the existing hardcoded listings:
 * image (or dark placeholder) | badges + title + description + metrics + highlights + CTA
 */
import type { Listing } from "../lib/listings";
import { formatPrice } from "../lib/listings";

interface Props {
  listing: Listing;
  /** "on-market" links to detail page; "off-market" triggers NDA modal */
  mode: "on-market" | "off-market";
}

const { listing, mode } = Astro.props;

const hasImage = !!listing.hero_image_url;
const isUnderContract = listing.status === "under_contract";
const detailUrl = mode === "on-market"
  ? `/deals/${listing.slug}`
  : `/off-market/${listing.slug}`;

// Metrics: use the flexible metrics JSON if available, otherwise build from DB fields
const metricsEntries: Array<{ label: string; value: string; highlight?: boolean }> =
  listing.metrics && Object.keys(listing.metrics).length > 0
    ? Object.entries(listing.metrics).map(([label, value], i, arr) => ({
        label,
        value,
        highlight: i === arr.length - 1,
      }))
    : [
        listing.asking_price ? { label: "Price", value: formatPrice(listing.asking_price) } : null,
        listing.cap_rate ? { label: "Cap Rate", value: `${listing.cap_rate}%` } : null,
        listing.noi ? { label: "NOI", value: formatPrice(listing.noi) } : null,
        listing.ebitda ? { label: "EBITDA", value: formatPrice(listing.ebitda), highlight: true } : null,
      ].filter(Boolean) as Array<{ label: string; value: string; highlight?: boolean }>;

const highlights = listing.highlights ?? [];
const badges = listing.display_badges ?? [];
---

<div class:list={[
  "flex flex-col lg:flex-row rounded-xl overflow-hidden border border-black/8 bg-white hover:shadow-lg transition-all",
  isUnderContract && "relative",
  mode === "off-market" && "cursor-pointer",
]}
  {...(mode === "off-market" ? { "data-nda-slug": listing.slug, "data-nda-title": listing.name } : {})}
>
  {/* Under Contract Banner */}
  {isUnderContract && (
    <div class="absolute top-0 left-0 right-0 z-10 bg-amber-500 text-white text-center py-2 text-[12px] font-bold tracking-widest uppercase">
      Under Contract at List Price
    </div>
  )}

  {/* Image or Placeholder */}
  {hasImage ? (
    <div class:list={[
      "w-full lg:w-[440px] h-[300px] lg:h-auto shrink-0 bg-gray-100 relative overflow-hidden",
      isUnderContract && "mt-[36px] lg:mt-0",
    ]}>
      <img
        src={listing.hero_image_url}
        alt={`${listing.name} — ${listing.city}, ${listing.state}`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      {/* Image overlay badges (first two from display_badges) */}
      {badges.length > 0 && (
        <span class:list={[
          "absolute top-4 left-4 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded",
          isUnderContract ? "bg-amber-500 lg:top-[48px]" : `bg-${badges[0].color || "red"}`,
        ]}
          style={`background-color: ${badges[0].color === "red" ? "#DA291C" : badges[0].color === "amber" ? "#f59e0b" : badges[0].color === "black" ? "#000" : badges[0].color}`}
        >
          {badges[0].text}
        </span>
      )}
      {badges.length > 1 && (
        <span class:list={[
          "absolute top-4 right-4 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded",
          isUnderContract && "lg:top-[48px]",
        ]}
          style={`background-color: ${badges[1].color === "black" ? "#000" : badges[1].color === "red" ? "#DA291C" : badges[1].color}`}
        >
          {badges[1].text}
        </span>
      )}
    </div>
  ) : (
    <div class="w-full lg:w-[440px] h-[300px] lg:h-auto shrink-0 relative overflow-hidden bg-gradient-to-br from-[#1a1e2e] via-[#2a2e3e] to-[#1a1e2e] flex items-center justify-center flex-col gap-2">
      {badges.length > 0 && (
        <span class="absolute top-4 left-4 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded"
          style={`background-color: ${badges[0].color === "red" ? "#DA291C" : badges[0].color === "black" ? "#000" : badges[0].color}`}
        >
          {badges[0].text}
        </span>
      )}
      <span class="absolute top-4 right-4 bg-black/75 text-white text-[10px] font-bold tracking-wider uppercase px-2.5 py-1 rounded">
        {mode === "off-market" ? "NDA Required" : "Coming Soon"}
      </span>
      <div class="w-12 h-12 border-2 border-white/15 rounded-full flex items-center justify-center text-white/30">
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
      </div>
      <span class="text-white/25 text-[11px] font-semibold tracking-[2px] uppercase">
        {listing.city}{listing.state ? `, ${listing.state}` : ""} &middot; Confidential
      </span>
    </div>
  )}

  {/* Content */}
  <div class:list={["p-10 flex-1", isUnderContract && "lg:pt-[52px]"]}>
    {/* Inline badges (tag style) */}
    {badges.length > 0 && (
      <div class="flex items-center gap-3 mb-4">
        {badges.map((badge) => (
          <span
            class="inline-block text-[10px] font-semibold px-2.5 py-1 rounded"
            style={`color: ${badge.color === "red" ? "#DA291C" : "#fff"}; background-color: ${badge.color === "red" ? "#fde8e8" : badge.color === "amber" ? "#f59e0b" : badge.color === "black" ? "#000" : badge.color}`}
          >
            {badge.text}
          </span>
        ))}
      </div>
    )}

    <h3 class="font-heading text-2xl lg:text-[28px] font-semibold text-black mb-4">{listing.name}</h3>

    {listing.website_description && (
      <p class="text-[15px] leading-relaxed text-gray-700 mb-4">
        {listing.website_description.length > 400
          ? listing.website_description.slice(0, 400).replace(/\s+\S*$/, "…")
          : listing.website_description}
      </p>
    )}

    {listing.city && (
      <p class="text-sm text-gray-500 mb-6">
        {[listing.city, listing.state].filter(Boolean).join(", ")}
        {listing.building_sqft ? ` · ${listing.building_sqft.toLocaleString()} SF` : ""}
        {listing.lot_acres ? ` · ${listing.lot_acres} AC` : ""}
        {listing.brand ? ` · ${listing.brand}` : ""}
      </p>
    )}

    {/* Metrics Grid */}
    {metricsEntries.length > 0 && (
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-6">
        {metricsEntries.map((m) => (
          <div>
            <div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider">{m.label}</div>
            <div class:list={["font-heading text-2xl font-bold", m.highlight ? "text-red" : "text-black"]}>
              {m.value}
            </div>
          </div>
        ))}
      </div>
    )}

    {/* Highlights */}
    {highlights.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {highlights.map((h) => (
          <span class="text-[11px] font-medium text-gray-600 bg-gray-100 px-3 py-1 rounded-full">{h}</span>
        ))}
      </div>
    )}

    {/* CTA */}
    {mode === "on-market" && !isUnderContract && (
      <a href={detailUrl} class="inline-flex items-center gap-2.5 bg-red text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors">
        Request Full Package
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    )}

    {mode === "on-market" && isUnderContract && (
      <div class="inline-flex items-center gap-2.5 bg-amber-500 text-white px-7 py-3.5 rounded-md text-[14px] font-semibold">
        Under Contract — Contact for Backup Position
      </div>
    )}

    {mode === "off-market" && (
      <button
        class="inline-flex items-center gap-2.5 bg-red text-white px-7 py-3.5 rounded-md text-[14px] font-semibold hover:bg-red-dark transition-colors border-none cursor-pointer font-body"
        data-nda-trigger
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        Unlock Full Details &rarr;
      </button>
    )}
  </div>
</div>
